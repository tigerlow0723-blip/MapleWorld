@Component
script UIMain extends Component

	property Entity sliderHP = nil

	property Entity sliderCost = nil

	property Entity txtHP = nil

	property Entity txtCost = nil

	property Entity sliderBossHP = nil

	property Entity txtBossHP = nil

	property Entity uiBossInfoGroup = nil

	property Entity uiBossSkill1 = nil

	property Entity uiBossSkill2 = nil

	property Entity uiBossSkill3 = nil

	property Entity uiBossSkill3_1 = nil

	property Entity uiBossSkill4 = nil

	property any shieldTimer = nil

	property Entity btnTurnEnd = nil

	property Entity btnBattleStart = nil

	property Entity uiPlayerTurn = nil

	property Entity uiMonsterTurn = nil

	property Entity uiBossTurn = nil

	property Entity txtStage = nil

	property Entity txtPlayerCoin = nil
	property Entity uiPlayerCoinPanel = nil
	property string playerCoinTextPath = "/ui/UIGroup/PlayerCoin/TxtPlayerCoin"
	property string playerCoinPanelPath = "/ui/UIGroup/PlayerCoin"
	property Entity uiStage5_1 = nil
	property Entity uiStage5_2 = nil
	property Entity uiStage5_3 = nil
	property Entity uiStage5_game = nil
	property Entity btnPlayOddEven = nil
	property Entity btnEnterShop = nil
	property Entity btnExitMiniGame = nil
	property Entity btnOdd = nil
	property Entity btnEven = nil
	property Entity btnBackFromPlay = nil
	property Entity btnSellAllOre = nil
	property Entity btnSellAllGoldBar = nil
	property Entity btnBackFromShop = nil
	property Entity stage5DiceImageEntity = nil
	property Entity stage5DiceImageEntity2 = nil
	property Entity stage5DiceRollEntity = nil
	property Entity stage5DiceRollEntity2 = nil
	property string stage5GamePath = "/ui/UIGroup/Stage_5_game"
	property string stage5DiceImagePath = "/ui/UIGroup/Stage_5_game/DiceResult"
	property string stage5DiceImagePath2 = "/ui/UIGroup/Stage_5_game/DiceResult2"
	property string stage5DiceRollPath = "/ui/UIGroup/Stage_5_game/DiceRoll"
	property string stage5DiceRollPath2 = "/ui/UIGroup/Stage_5_game/DiceRoll2"
	property table stage5DiceImageRUIDs = {}
	property table stage5DiceImageRUIDs2 = {}
	property table stage5DiceRollRUIDs = {}
	property table stage5DiceRollRUIDs2 = {}
	property Entity uiClear = nil
	property Entity uiFail = nil
	property Entity btnRetry = nil
	property string scrollPanelPath = "/ui/UIGroup/ScrollPanel"
	property string itemDisplayAreaPath = "/ui/UIGroup/ItemDisplayArea"
	property string rewardPanelPath = "/ui/UIGroup/RewardPanel"
	property Entity scrollPanelEntity = nil
	property Entity itemDisplayAreaEntity = nil
	property Entity rewardPanelEntity = nil
	property any gameManager = nil
	property any battleManager = nil
	property any playerManager = nil
	property any scrollInventoryUI = nil
	
	-- Main Menu Properties
	property Entity uiMainMenu = nil
	property Entity btnStartGame = nil
	property Entity btnHowToPlay = nil
	
	-- Tutorial Properties
	property Entity uiTutorial = nil
	property Entity btnNextPage = nil
	property Entity btnPrevPage = nil
	property Entity btnCloseTutorial = nil
	property integer currentTutorialPage = 1
	property table tutorialImages = {} -- user fills in RUIDs here
	
	property any rewardUI = nil
	property integer targetMonsterIdx = 0
	property table monsterSliders = {}
	property integer lastBossPhase = 0

		method void InitializeUI(any gameMgr, any battleMgr, any playerMgr)
		local function disableInteract(ent)
			if ent ~= nil then
				local canvas = ent.CanvasGroupComponent
				if canvas == nil then
					canvas = ent:AddComponent("CanvasGroupComponent")
				end
				if canvas ~= nil then
					canvas.Interactable = false
				end
			end
		end
		
		disableInteract(self.sliderHP)
		disableInteract(self.sliderCost)
		disableInteract(self.sliderBossHP)

        log("[UIMain] InitializeUI called")
		self.gameManager = gameMgr
		self.battleManager = battleMgr
		self.playerManager = playerMgr
		self:ResolveRewardUI()
		
		self:ConnectEvents()
		self:ResetBossSkillUI() -- Ensure boss skills are hidden at the very beginning
		self:HideStage5DiceVisual()
		
		if self.uiClear ~= nil then
			self.uiClear.Enable = false
		end
		if self.uiFail ~= nil then
			self.uiFail.Enable = false
		end
		
		self:UpdateUI() -- ??��?????????UI 갱�??(명�??????��??
        log("[UIMain] UI initialized")
	end

	method void ResolveRewardUI()
		if self.rewardUI ~= nil then
			return
		end
		-- Always hide dice visuals at bind time to prevent default-visible leakage.
		self:HideStage5DiceVisual()

		local rewardPanel = _EntityService:GetEntityByPath(self.rewardPanelPath)
		if rewardPanel ~= nil then
			self.rewardUI = rewardPanel.RewardUI
		end
		
		-- Bind Main Menu UI
		self.uiMainMenu = _EntityService:GetEntityByPath("/ui/maingroup/mainscreen")
		if self.uiMainMenu ~= nil then
			self.btnStartGame = self.uiMainMenu:GetChildByName("start")
			self.btnHowToPlay = self.uiMainMenu:GetChildByName("ex")
		end
		
		-- Bind Tutorial UI (explanation_screen must be Enable=true in Maker so GetEntityByPath can find it)
		self.uiTutorial = _EntityService:GetEntityByPath("/ui/maingroup/explanation_screen")
		if self.uiTutorial ~= nil then
			self.btnNextPage = self.uiTutorial:GetChildByName("right")
			self.btnPrevPage = self.uiTutorial:GetChildByName("left")
			self.btnCloseTutorial = self.uiTutorial:GetChildByName("Exit")
			

			-- Load tutorial image RUIDs from DataManager
			if self.gameManager ~= nil and self.gameManager.dataManager ~= nil then
				local imgTable = self.gameManager.dataManager.TutorialImageTable
				if imgTable ~= nil then
					self.tutorialImages = {}
					for page = 1, 13 do
						if imgTable[page] ~= nil then
							self.tutorialImages[page] = imgTable[page]
						else
							self.tutorialImages[page] = ""
						end
					end
					log("[UIMain] Tutorial images loaded from DataManager: " .. tostring(#self.tutorialImages))
				end

				if self.gameManager.dataManager.DiceImageTable ~= nil then
					self.stage5DiceImageRUIDs = self.gameManager.dataManager.DiceImageTable
				end
				if self.gameManager.dataManager.DiceImageTable2 ~= nil then
					self.stage5DiceImageRUIDs2 = self.gameManager.dataManager.DiceImageTable2
				end
				if self.gameManager.dataManager.DiceRollTable ~= nil then
					self.stage5DiceRollRUIDs = self.gameManager.dataManager.DiceRollTable
				end
				if self.gameManager.dataManager.DiceRollTable2 ~= nil then
					self.stage5DiceRollRUIDs2 = self.gameManager.dataManager.DiceRollTable2
				end
			end

			-- Hide tutorial screen initially (it must be enabled in Maker for binding to work)
			self.uiTutorial.Enable = false
			log("[UIMain] explanation_screen bound and hidden successfully")
		else
			log("[UIMain] WARNING: explanation_screen NOT found - make sure it is ENABLED in Maker!")
		end
		
		-- Bind Stage 5 mini-game UI (supports renamed buttons)
		self.uiStage5_1 = _EntityService:GetEntityByPath("/ui/UIGroup/Stage_5_1")
		if self.uiStage5_1 ~= nil then
			self.btnPlayOddEven = self.uiStage5_1:GetChildByName("minigame")
			self.btnEnterShop = self.uiStage5_1:GetChildByName("entershop")
			self.btnExitMiniGame = self.uiStage5_1:GetChildByName("exitminigame")
		end
		
		self.uiStage5_2 = _EntityService:GetEntityByPath("/ui/UIGroup/Stage_5_2")
		if self.uiStage5_2 ~= nil then
			self.btnOdd = self.uiStage5_2:GetChildByName("playoddeven_1")
			self.btnEven = self.uiStage5_2:GetChildByName("playoddeven_2")
			self.btnBackFromPlay = self.uiStage5_2:GetChildByName("backtomian")
		end
		
		self.uiStage5_3 = _EntityService:GetEntityByPath("/ui/UIGroup/Stage_5_3")
		if self.uiStage5_3 ~= nil then
			self.btnSellAllOre = self.uiStage5_3:GetChildByName("sellallore")
			self.btnSellAllGoldBar = self.uiStage5_3:GetChildByName("sellallgoldbar")
			self.btnBackFromShop = self.uiStage5_3:GetChildByName("backtomian")
		end
		
		-- Find Stage_5_game via parent (GetEntityByPath cannot find disabled entities)
		local uiGroupEntity = _EntityService:GetEntityByPath("/ui/UIGroup")
		if self.uiStage5_game == nil then
			if self.stage5GamePath ~= nil and self.stage5GamePath ~= "" then
				self.uiStage5_game = _EntityService:GetEntityByPath(self.stage5GamePath)
			end
			if self.uiStage5_game == nil and uiGroupEntity ~= nil then
				self.uiStage5_game = uiGroupEntity:GetChildByName("Stage_5_game")
			end
		end
		if self.uiStage5_game ~= nil then
			if self.stage5DiceImageEntity == nil then
				self.stage5DiceImageEntity = self.uiStage5_game:GetChildByName("DiceResult")
			end
			if self.stage5DiceImageEntity2 == nil then
				self.stage5DiceImageEntity2 = self.uiStage5_game:GetChildByName("DiceResult2")
			end
			if self.stage5DiceRollEntity == nil then
				self.stage5DiceRollEntity = self.uiStage5_game:GetChildByName("DiceRoll")
			end
			if self.stage5DiceRollEntity2 == nil then
				self.stage5DiceRollEntity2 = self.uiStage5_game:GetChildByName("DiceRoll2")
			end
		end

		self:ResolvePlayerCoinUI()
	end

	method void ResolvePlayerCoinUI()
		if self.uiPlayerCoinPanel == nil then
			self.uiPlayerCoinPanel = _EntityService:GetEntityByPath(self.playerCoinPanelPath)
		end
		if self.txtPlayerCoin == nil then
			self.txtPlayerCoin = _EntityService:GetEntityByPath(self.playerCoinTextPath)
			if self.txtPlayerCoin == nil and self.uiPlayerCoinPanel ~= nil then
				self.txtPlayerCoin = self.uiPlayerCoinPanel:GetChildByName("TxtPlayerCoin", true)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		self:UpdateMonsterHPBars()
	end

	method void ConnectEvents()
		-- Main Menu / Tutorial Buttons
		if self.btnStartGame ~= nil then
			self.btnStartGame:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				self:HideMainMenu()
				if self.gameManager ~= nil then
					self.gameManager:StartGame("War")
				end
			end)
		end
		
		if self.btnHowToPlay ~= nil then
			self.btnHowToPlay:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				log("[UIMain] === Explanation button CLICKED! ===")
				
				-- Hide Main_screen directly by path
				local mainScreen = _EntityService:GetEntityByPath("/ui/maingroup/mainscreen")
				if mainScreen ~= nil then
					mainScreen:SetEnable(false)
					log("[UIMain] Main_screen hidden")
				else
					log("[UIMain] WARNING: Main_screen not found by path")
				end
				
				-- Show explanation_screen directly by path
				local tutScreen = _EntityService:GetEntityByPath("/ui/maingroup/explanation_screen")
				if tutScreen ~= nil then
					tutScreen:SetEnable(true)
					self.currentTutorialPage = 1
					self:UpdateTutorialImage()
					log("[UIMain] explanation_screen shown")
				else
					log("[UIMain] WARNING: explanation_screen not found by path")
				end
			end)
			log("[UIMain] explanation button event connected!")
		else
			log("[UIMain] WARNING: btnHowToPlay is nil, cannot connect event!")
		end
		
		if self.btnNextPage ~= nil then
			self.btnNextPage:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.currentTutorialPage < #self.tutorialImages then
					self.currentTutorialPage = self.currentTutorialPage + 1
					self:UpdateTutorialImage()
				end
			end)
		end
		
		if self.btnPrevPage ~= nil then
			self.btnPrevPage:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.currentTutorialPage > 1 then
					self.currentTutorialPage = self.currentTutorialPage - 1
					self:UpdateTutorialImage()
				end
			end)
		end
		
		if self.btnCloseTutorial ~= nil then
			self.btnCloseTutorial:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				local tutScreen = _EntityService:GetEntityByPath("/ui/maingroup/explanation_screen")
				if tutScreen ~= nil then
					tutScreen:SetEnable(false)
				end
				local mainScreen = _EntityService:GetEntityByPath("/ui/maingroup/mainscreen")
				if mainScreen ~= nil then
					mainScreen:SetEnable(true)
				end
			end)
		end
		
		-- ????��??버�??
		if self.btnTurnEnd ~= nil then
			self.btnTurnEnd:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end 
				if self.gameManager == nil or self.gameManager.gamePhase ~= "Battle" then
					return
				end
				self.battleManager:EndPlayerTurn()
				self:UpdateUI()
			end)
		end
		
		-- ??????????��??버�??
		if self.btnBattleStart ~= nil then
			self.btnBattleStart:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager ~= nil and self.gameManager.gamePhase == "Preparation" then
					if self.gameManager.canEndPreparation == true then
						self.gameManager:EndPreparation()
						return
					end
		
					self.gameManager:TriggerBattleStart()
				end
			end)
		end
		
		-- ==========================================
		-- 미�??�???? 버�?????��?????��??????��??
		-- ==========================================
		if self.btnPlayOddEven ~= nil then
			self.btnPlayOddEven:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:EnterSubPlay()
				end
			end)
		end
		if self.btnEnterShop ~= nil then
			self.btnEnterShop:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:EnterSubShop()
				end
			end)
		end
		if self.btnExitMiniGame ~= nil then
			self.btnExitMiniGame:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:ExitMiniGame()
				end
			end)
		end
		
		if self.btnOdd ~= nil then
			self.btnOdd:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:PlayOddEven(1)
				end
			end)
		end
		if self.btnEven ~= nil then
			self.btnEven:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:PlayOddEven(2)
				end
			end)
		end
		if self.btnBackFromPlay ~= nil then
			self.btnBackFromPlay:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:ExitMiniGame()
				end
			end)
		end
		
		if self.btnSellAllOre ~= nil then
			self.btnSellAllOre:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager and self.gameManager.miniGameManager.SellAllOre ~= nil then
					self.gameManager.miniGameManager:SellAllOre()
				end
			end)
		end
		if self.btnSellAllGoldBar ~= nil then
			self.btnSellAllGoldBar:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:SellAllGoldBar()
				end
			end)
		end
		if self.btnBackFromShop ~= nil then
			self.btnBackFromShop:ConnectEvent("ButtonClickEvent", function()
				if self.gameManager and self.gameManager.soundManager then self.gameManager.soundManager:PlaySFX(5004) end
				if self.gameManager and self.gameManager.miniGameManager then
					self.gameManager.miniGameManager:ExitMiniGame()
				end
			end)
		end
	end

	method void RefreshScrollInventoryUI()
		if self.scrollInventoryUI == nil then
			local scrollPanel = _EntityService:GetEntityByPath(self.scrollPanelPath)
			if scrollPanel == nil then
				scrollPanel = _EntityService:GetEntityByPath("/ui/UIGroup")
			end
			if scrollPanel ~= nil then
				self.scrollInventoryUI = scrollPanel.ScrollInventoryUI
			end
		end
		
		if self.scrollInventoryUI ~= nil then
			self.scrollInventoryUI:UpdateUI()
		end
	end

	method void ResolvePhasePanelEntities()
		if self.scrollPanelEntity == nil then
			self.scrollPanelEntity = _EntityService:GetEntityByPath(self.scrollPanelPath)
		end
		if self.itemDisplayAreaEntity == nil then
			self.itemDisplayAreaEntity = _EntityService:GetEntityByPath(self.itemDisplayAreaPath)
		end
		if self.rewardPanelEntity == nil then
			self.rewardPanelEntity = _EntityService:GetEntityByPath(self.rewardPanelPath)
			if self.rewardPanelEntity == nil and self.rewardUI ~= nil then
				if self.rewardUI.rewardPanelEntity ~= nil then
					self.rewardPanelEntity = self.rewardUI.rewardPanelEntity
				elseif self.rewardUI.Entity ~= nil then
					self.rewardPanelEntity = self.rewardUI.Entity
				end
			end
		end
	end

	method boolean IsRewardChestPhase(string phase)
		if phase ~= "Preparation" then
			return false
		end

		local rewardPanelOpen = false
		local rewardPanel = self.rewardPanelEntity
		if rewardPanel == nil and self.rewardUI ~= nil then
			if self.rewardUI.rewardPanelEntity ~= nil then
				rewardPanel = self.rewardUI.rewardPanelEntity
			elseif self.rewardUI.Entity ~= nil then
				rewardPanel = self.rewardUI.Entity
			end
			self.rewardPanelEntity = rewardPanel
		end
		if rewardPanel ~= nil and rewardPanel.Enable == true then
			rewardPanelOpen = true
		end

		local rewardChestActive = false
		if self.gameManager ~= nil and self.gameManager.rewardChestEntity ~= nil and self.gameManager.rewardChestEntity.Enable == true then
			rewardChestActive = true
		end

		return rewardPanelOpen or rewardChestActive
	end

	method void UpdatePhasePanelVisibility(string phase)
		self:ResolvePhasePanelEntities()
		local isRewardChestPhase = self:IsRewardChestPhase(phase)
		local isStageTransitioning = false
		if self.gameManager ~= nil and self.gameManager.isStageTransitioning == true then
			isStageTransitioning = true
		end

		if self.itemDisplayAreaEntity ~= nil then
			if phase == "Battle" or phase == "MiniGame" or isRewardChestPhase or isStageTransitioning then
				self.itemDisplayAreaEntity:SetEnable(false)
				self.itemDisplayAreaEntity:SetVisible(false)
			elseif phase == "Preparation" or phase == "Shop" then
				self.itemDisplayAreaEntity:SetEnable(true)
				self.itemDisplayAreaEntity:SetVisible(true)
			end
		end

		if self.scrollPanelEntity ~= nil then
			if phase == "Battle" then
				self.scrollPanelEntity:SetEnable(false)
				self.scrollPanelEntity:SetVisible(false)
			elseif phase == "Preparation" or phase == "Shop" then
				self.scrollPanelEntity:SetEnable(true)
				self.scrollPanelEntity:SetVisible(true)
			end
		end
	end
	method void ShowMainMenu()
		local mainGroup = _EntityService:GetEntityByPath("/ui/maingroup")
		if mainGroup ~= nil then
			mainGroup.Enable = true
		end
		
		if self.uiMainMenu ~= nil then
			self.uiMainMenu.Enable = true
		end
		if self.uiTutorial ~= nil then
			self.uiTutorial.Enable = false
		end
		-- Hide standard game UI
		local uiGroup = _EntityService:GetEntityByPath("/ui/UIGroup")
		if uiGroup ~= nil then
			uiGroup.Enable = false
		end
	end
	
	method void HideMainMenu()
		if self.uiMainMenu ~= nil then
			self.uiMainMenu.Enable = false
		end
		if self.uiTutorial ~= nil then
			self.uiTutorial.Enable = false
		end
		
		local mainGroup = _EntityService:GetEntityByPath("/ui/maingroup")
		if mainGroup ~= nil then
			mainGroup.Enable = false
		end
		
		local uiGroup = _EntityService:GetEntityByPath("/ui/UIGroup")
		if uiGroup ~= nil then
			uiGroup.Enable = true
		end
	end

	method void UpdateTutorialImage()
		if self.uiTutorial == nil then return end
		-- Update the image using SpriteRendererComponent attached to uiTutorial
		local spriteComp = self.uiTutorial.SpriteRendererComponent
		if spriteComp == nil then
			-- It may be an ImageComponent if it's UI
			spriteComp = self.uiTutorial.SpriteGUIRendererComponent
		end
		if spriteComp ~= nil then
			local ruid = self.tutorialImages[self.currentTutorialPage]
			if ruid ~= nil and ruid ~= "" and ruid ~= "FillMe" .. tostring(self.currentTutorialPage) then
				spriteComp.ImageRUID = ruid
			else
				log("[UIMain] Missing Tutorial RUID for page: " .. tostring(self.currentTutorialPage))
			end
		end
	end

	method void UpdateUI()
		if self.playerManager == nil then return end
		
		self:RefreshScrollInventoryUI()
		
		-- ???��??강�??갱�??(몬스???��?? 죽�????????????��??가 바�???????????��?????��??
		if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
			local canShowTarget = false
			if self.gameManager ~= nil and self.gameManager.gamePhase == "Battle" and self.targetMonsterIdx ~= nil and self.targetMonsterIdx > 0 then
				canShowTarget = true
			end
			
			if canShowTarget == true then
				self.battleManager.monsterManager:UpdateTargetHighlight(self.targetMonsterIdx)
			else
				self.battleManager.monsterManager:UpdateTargetHighlight(0)
			end
		end
		
		-- 1. HP 게�??�? ???��????????
		if self.sliderHP ~= nil then
			local maxHP = self.playerManager.maxHP
			local ratio = 0
			if maxHP > 0 then
				ratio = self.playerManager.currentHP / maxHP
			end
			-- Entity???��??SliderComponent 찾�????????��??
			local slider = self.sliderHP.SliderComponent
			if slider ~= nil then
				slider.Value = ratio
			end
		end
		if self.txtHP ~= nil then
			local txt = self.txtHP.TextComponent
			if txt ~= nil then
				txt.Text = math.ceil(self.playerManager.currentHP) .. "/" .. math.ceil(self.playerManager.maxHP)
			end
		end
		
		-- 1.5. Monster HP Bars (Cloned Sliders mapped to World Space)
		self:UpdateMonsterHPBars()
		
		-- 2. Cost 게�??�? ???��????????
		if self.sliderCost ~= nil then
			local maxCost = self.playerManager.maxCost
			local ratio = 0
			if maxCost > 0 then
				ratio = self.playerManager.currentCost / maxCost
			end
			local slider = self.sliderCost.SliderComponent
			if slider ~= nil then
				slider.Value = ratio
			end
		end
		if self.txtCost ~= nil then
			local txt = self.txtCost.TextComponent
			if txt ~= nil then
				txt.Text = math.ceil(self.playerManager.currentCost) .. "/" .. math.ceil(self.playerManager.maxCost)
			end
		end

		self:ResolvePlayerCoinUI()
		if self.uiPlayerCoinPanel ~= nil then
			self.uiPlayerCoinPanel:SetEnable(true)
			self.uiPlayerCoinPanel:SetVisible(true)
		end
		if self.txtPlayerCoin ~= nil then
			local coinText = self.txtPlayerCoin.TextComponent
			if coinText ~= nil then
				coinText.Text = tostring(self.playerManager.gold or 0)
			end
		end
		-- 3. ?????????��?? ???��??(TextComponent가 ???��???????????��??�?가??
		if self.txtStage ~= nil and self.battleManager ~= nil then
			local txt = self.txtStage.TextComponent
			if txt ~= nil then
				txt.Text = "Stage: " .. tostring(self.battleManager.currentStage)
			end
		end
		
		-- 3.5 보�??�????�????��????????
		if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
			local monsterMgr = self.battleManager.monsterManager
			if monsterMgr.isBossBattle and self.uiBossInfoGroup ~= nil then
				self.uiBossInfoGroup.Enable = true
				-- Removed self:SetBossSkillUIEnable(true) here: skills should stay hidden until used
				
				-- 보�????�스???��???보�??????????찾�??
				local boss = nil
				for i = 1, #monsterMgr.monsterList do
					local m = monsterMgr.monsterList[i]
					if m.isBoss and m.alive then
						boss = m
						break
					end
				end
				
				if boss ~= nil then
					local currentMaxHP = boss.maxHP
					local currentHP = boss.currentHP
					local currentPhase = monsterMgr.currentBossPhase
					
					-- Detect if boss phase just changed so we can force animation from 0
					local phaseChanged = false
					if self.lastBossPhase == nil or self.lastBossPhase ~= currentPhase then
						self.lastBossPhase = currentPhase
						phaseChanged = true
					end
					
					if self.sliderBossHP ~= nil then
						local slider = self.sliderBossHP.SliderComponent
						if slider ~= nil then
							local targetRatio = 0
							if currentMaxHP > 0 then
								targetRatio = currentHP / currentMaxHP
							end
							
							if phaseChanged then
								slider.Value = 0 -- Force start from 0
							end
							
							-- If the difference is significant (e.g., phase change full heal), animate it
							if phaseChanged or math.abs(slider.Value - targetRatio) > 0.05 then
								local startVal = slider.Value
								-- Text Animation state capture
								local startHPVal = startVal * currentMaxHP
								
								_TweenLogic:PlayTween(0, 1, 1.0, EaseType.QuadEaseOut, function(t)
									if _EntityService:IsValid(self.sliderBossHP) then
										local s = self.sliderBossHP.SliderComponent
										if s ~= nil then
											-- Lerp the slider
											s.Value = startVal + (targetRatio - startVal) * t
										end
									end
									
									if self.txtBossHP ~= nil and _EntityService:IsValid(self.txtBossHP) then
										local txt = self.txtBossHP.TextComponent
										if txt ~= nil then
											-- Lerp the text
											local animHP = startHPVal + (currentHP - startHPVal) * t
											txt.Text = math.ceil(animHP) .. "/" .. math.ceil(currentMaxHP)
										end
									end
								end)
							else
								slider.Value = targetRatio
								if self.txtBossHP ~= nil then
									local txt = self.txtBossHP.TextComponent
									if txt ~= nil then
										txt.Text = math.ceil(currentHP) .. "/" .. math.ceil(currentMaxHP)
									end
								end
							end
						end
					end
				else
					if self.uiBossInfoGroup ~= nil then
						self.uiBossInfoGroup.Enable = false
					end
					self:SetBossSkillUIEnable(false)
				end
			else
				if self.uiBossInfoGroup ~= nil then
					self.uiBossInfoGroup.Enable = false
				end
				self:SetBossSkillUIEnable(false)
			end
		else
			if self.uiBossInfoGroup ~= nil then
				self.uiBossInfoGroup.Enable = false
			end
			self:SetBossSkillUIEnable(false)
		end
		
		-- Button 가???��?????��??(Preparation vs Battle)
		local phase = "None"
		if self.gameManager ~= nil then
			phase = self.gameManager.gamePhase
		end
		local isRewardChestPhase = self:IsRewardChestPhase(phase)
		self:UpdatePhasePanelVisibility(phase)
		
		if self.btnBattleStart ~= nil then
			local canShowBattleStart = (phase == "Preparation" and isRewardChestPhase == false)
			if canShowBattleStart and self.itemDisplayAreaEntity ~= nil then
				canShowBattleStart = (self.itemDisplayAreaEntity.Enable == true)
			end
			self.btnBattleStart.Enable = canShowBattleStart
		end
		
		if self.btnTurnEnd ~= nil then
			-- Only show turn end button during player's turn in battle
			local isPlayerTurn = false
			if phase == "Battle" and self.battleManager ~= nil and self.battleManager.currentTurn == "Player" then
				isPlayerTurn = true
			end
			
			local canAct = true
			if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
				local mgr = self.battleManager.monsterManager
				if mgr.IsSpawnEntranceFinished ~= nil and not mgr:IsSpawnEntranceFinished() then
					canAct = false
				elseif mgr.isPhaseTransitioning == true or mgr.isDyingAnimating == true then
					canAct = false
				end
			end
			
			self.btnTurnEnd.Enable = isPlayerTurn and canAct
		end
		
		-- Turn Indicator UI Control
		if phase == "Battle" and self.battleManager ~= nil then
			local currentTurn = self.battleManager.currentTurn
			if self.uiPlayerTurn ~= nil then
				self.uiPlayerTurn.Enable = (currentTurn == "Player")
			end
			
			local isBossBattle = false
			if self.battleManager.monsterManager ~= nil and self.battleManager.monsterManager.isBossBattle then
				isBossBattle = true
			end
			
			if currentTurn == "Monster" then
				if isBossBattle then
					if self.uiBossTurn ~= nil then self.uiBossTurn.Enable = true end
					if self.uiMonsterTurn ~= nil then self.uiMonsterTurn.Enable = false end
				else
					if self.uiBossTurn ~= nil then self.uiBossTurn.Enable = false end
					if self.uiMonsterTurn ~= nil then self.uiMonsterTurn.Enable = true end
				end
			else
				if self.uiBossTurn ~= nil then self.uiBossTurn.Enable = false end
				if self.uiMonsterTurn ~= nil then self.uiMonsterTurn.Enable = false end
			end
		else
			if self.uiPlayerTurn ~= nil then self.uiPlayerTurn.Enable = false end
			if self.uiMonsterTurn ~= nil then self.uiMonsterTurn.Enable = false end
			if self.uiBossTurn ~= nil then self.uiBossTurn.Enable = false end
		end
		
		-- 4. 미�??�???? ???��??메�??가???��?????��??
        if phase == "MiniGame" then
            -- Find Stage_5_game via GetChildByName (GetEntityByPath cannot find disabled entities)
            if self.uiStage5_game == nil then
                self.uiStage5_game = _EntityService:GetEntityByPath(self.stage5GamePath)
                if self.uiStage5_game == nil then
                    local uiGroup = _EntityService:GetEntityByPath("/ui/UIGroup")
                    if uiGroup ~= nil then
                        self.uiStage5_game = uiGroup:GetChildByName("Stage_5_game")
                    end
                end
            end
            if self.uiStage5_game ~= nil then
                self.uiStage5_game.Enable = true
                if self.stage5DiceImageEntity == nil then
                    self.stage5DiceImageEntity = self.uiStage5_game:GetChildByName("DiceResult")
                end
                if self.stage5DiceImageEntity2 == nil then
                    self.stage5DiceImageEntity2 = self.uiStage5_game:GetChildByName("DiceResult2")
                end
                if self.stage5DiceRollEntity == nil then
                    self.stage5DiceRollEntity = self.uiStage5_game:GetChildByName("DiceRoll")
                end
                if self.stage5DiceRollEntity2 == nil then
                    self.stage5DiceRollEntity2 = self.uiStage5_game:GetChildByName("DiceRoll2")
                end
            end

            log("[UIMain-DEBUG] MiniGame phase. uiStage5_game=" .. tostring(self.uiStage5_game ~= nil) .. " diceRoll=" .. tostring(self.stage5DiceRollEntity ~= nil) .. " diceRoll2=" .. tostring(self.stage5DiceRollEntity2 ~= nil) .. " diceImg=" .. tostring(self.stage5DiceImageEntity ~= nil) .. " diceImg2=" .. tostring(self.stage5DiceImageEntity2 ~= nil) .. " rollRUID1=" .. tostring(self.stage5DiceRollRUIDs) .. " rollRUID2=" .. tostring(self.stage5DiceRollRUIDs2))
            if self.gameManager ~= nil and self.gameManager.miniGameManager ~= nil then
                local subState = self.gameManager.miniGameManager.subState
                if self.uiStage5_1 ~= nil then self.uiStage5_1.Enable = (subState == "Main") end
                if self.uiStage5_2 ~= nil then self.uiStage5_2.Enable = (subState == "Play") end
                if self.uiStage5_3 ~= nil then self.uiStage5_3.Enable = (subState == "Shop") end
                if self.uiStage5_game ~= nil then self.uiStage5_game.Enable = (subState == "Roll" or subState == "Roll2" or subState == "Result") end

                if subState == "Roll" then
                    self:UpdateStage5DiceRollVisual()
                elseif subState == "Roll2" then
                    self:UpdateStage5DiceRoll2Visual()
                elseif subState == "Result" then
                    self:UpdateStage5DiceResult()
                else
                    self:HideStage5DiceVisual()
                end
            else
                self:HideStage5DiceVisual()
            end
        else
            if self.uiStage5_1 ~= nil then self.uiStage5_1.Enable = false end
            if self.uiStage5_2 ~= nil then self.uiStage5_2.Enable = false end
            if self.uiStage5_3 ~= nil then self.uiStage5_3.Enable = false end
            if self.uiStage5_game ~= nil then self.uiStage5_game.Enable = false end
            self:HideStage5DiceVisual()
        end
    end

	method void HideStage5DiceVisual()
		if self.stage5DiceRollEntity ~= nil then
			self.stage5DiceRollEntity.Enable = false
		end
		if self.stage5DiceRollEntity2 ~= nil then
			self.stage5DiceRollEntity2.Enable = false
		end
		if self.stage5DiceImageEntity ~= nil then
			self.stage5DiceImageEntity.Enable = false
		end
		if self.stage5DiceImageEntity2 ~= nil then
			self.stage5DiceImageEntity2.Enable = false
		end
	end

	method void UpdateStage5DiceRollVisual()
		if self.gameManager == nil or self.gameManager.miniGameManager == nil then
			return
		end
		local roll = tonumber(self.gameManager.miniGameManager.lastDiceRoll) or 0
		local roll2 = tonumber(self.gameManager.miniGameManager.lastDiceRoll2) or 0
		
		if self.stage5DiceRollEntity ~= nil then
			if self.stage5DiceRollRUIDs ~= nil and roll >= 1 and roll <= 7 and self.stage5DiceRollRUIDs[roll] ~= nil and self.stage5DiceRollRUIDs[roll] ~= "" then
				local gui = self.stage5DiceRollEntity.SpriteGUIRendererComponent
				if gui ~= nil then
					gui.ImageRUID = self.stage5DiceRollRUIDs[roll]
				else
					local sprite = self.stage5DiceRollEntity.SpriteRendererComponent
					if sprite ~= nil then
						sprite.SpriteRUID = self.stage5DiceRollRUIDs[roll]
					end
				end
			end
			self.stage5DiceRollEntity.Enable = true
		end
		if self.stage5DiceRollEntity2 ~= nil then
			if self.stage5DiceRollRUIDs2 ~= nil and roll2 >= 1 and roll2 <= 7 and self.stage5DiceRollRUIDs2[roll2] ~= nil and self.stage5DiceRollRUIDs2[roll2] ~= "" then
				local gui2 = self.stage5DiceRollEntity2.SpriteGUIRendererComponent
				if gui2 ~= nil then
					gui2.ImageRUID = self.stage5DiceRollRUIDs2[roll2]
				else
					local sprite2 = self.stage5DiceRollEntity2.SpriteRendererComponent
					if sprite2 ~= nil then
						sprite2.SpriteRUID = self.stage5DiceRollRUIDs2[roll2]
					end
				end
				self.stage5DiceRollEntity2.Enable = true
			else
				self.stage5DiceRollEntity2.Enable = false
			end
		end
		if self.stage5DiceImageEntity ~= nil then
			self.stage5DiceImageEntity.Enable = false
		end
		if self.stage5DiceImageEntity2 ~= nil then
			self.stage5DiceImageEntity2.Enable = false
		end
	end
	method void UpdateStage5DiceRoll2Visual()
		if self.gameManager == nil or self.gameManager.miniGameManager == nil then
			return
		end
		local roll = tonumber(self.gameManager.miniGameManager.lastDiceRoll) or 0
		local roll2 = tonumber(self.gameManager.miniGameManager.lastDiceRoll2) or 0
		if self.stage5DiceRollEntity ~= nil then
			self.stage5DiceRollEntity.Enable = false
		end
		if self.stage5DiceImageEntity ~= nil then
			if self.stage5DiceImageRUIDs ~= nil and roll >= 1 and roll <= 7 and self.stage5DiceImageRUIDs[roll] ~= nil and self.stage5DiceImageRUIDs[roll] ~= "" then
				local gui = self.stage5DiceImageEntity.SpriteGUIRendererComponent
				if gui ~= nil then
					gui.ImageRUID = self.stage5DiceImageRUIDs[roll]
				else
					local sprite = self.stage5DiceImageEntity.SpriteRendererComponent
					if sprite ~= nil then
						sprite.SpriteRUID = self.stage5DiceImageRUIDs[roll]
					end
				end
			end
			self.stage5DiceImageEntity.Enable = true
		end
		if self.stage5DiceRollEntity2 ~= nil then
			if self.stage5DiceRollRUIDs2 ~= nil and roll2 >= 1 and roll2 <= 7 and self.stage5DiceRollRUIDs2[roll2] ~= nil and self.stage5DiceRollRUIDs2[roll2] ~= "" then
				local gui2 = self.stage5DiceRollEntity2.SpriteGUIRendererComponent
				if gui2 ~= nil then
					gui2.ImageRUID = self.stage5DiceRollRUIDs2[roll2]
				else
					local sprite2 = self.stage5DiceRollEntity2.SpriteRendererComponent
					if sprite2 ~= nil then
						sprite2.SpriteRUID = self.stage5DiceRollRUIDs2[roll2]
					end
				end
				self.stage5DiceRollEntity2.Enable = true
			else
				self.stage5DiceRollEntity2.Enable = false
			end
		end
		if self.stage5DiceImageEntity2 ~= nil then
			self.stage5DiceImageEntity2.Enable = false
		end
	end

		method void UpdateStage5DiceResult()
		if self.gameManager == nil or self.gameManager.miniGameManager == nil then
			return
		end
		if self.stage5DiceRollEntity ~= nil then
			self.stage5DiceRollEntity.Enable = false
		end
		if self.stage5DiceRollEntity2 ~= nil then
			self.stage5DiceRollEntity2.Enable = false
		end
		if self.stage5DiceImageEntity == nil and self.stage5DiceImageEntity2 == nil then
			return
		end
		
		local roll = tonumber(self.gameManager.miniGameManager.lastDiceRoll) or 0
		local roll2 = tonumber(self.gameManager.miniGameManager.lastDiceRoll2) or 0
		if roll < 1 or roll > 7 then
			return
		end
		if roll2 < 1 or roll2 > 7 then
			return
		end
		
		if self.stage5DiceImageEntity ~= nil then
			self.stage5DiceImageEntity.Enable = true
			if self.stage5DiceImageRUIDs ~= nil and self.stage5DiceImageRUIDs[roll] ~= nil and self.stage5DiceImageRUIDs[roll] ~= "" then
				local gui = self.stage5DiceImageEntity.SpriteGUIRendererComponent
				if gui ~= nil then
					gui.ImageRUID = self.stage5DiceImageRUIDs[roll]
				else
					local sprite = self.stage5DiceImageEntity.SpriteRendererComponent
					if sprite ~= nil then
						sprite.SpriteRUID = self.stage5DiceImageRUIDs[roll]
					end
				end
			end
		end
		
		if self.stage5DiceImageEntity2 ~= nil then
			self.stage5DiceImageEntity2.Enable = true
			if self.stage5DiceImageRUIDs2 ~= nil and self.stage5DiceImageRUIDs2[roll2] ~= nil and self.stage5DiceImageRUIDs2[roll2] ~= "" then
				local gui2 = self.stage5DiceImageEntity2.SpriteGUIRendererComponent
				if gui2 ~= nil then
					gui2.ImageRUID = self.stage5DiceImageRUIDs2[roll2]
				else
					local sprite2 = self.stage5DiceImageEntity2.SpriteRendererComponent
					if sprite2 ~= nil then
						sprite2.SpriteRUID = self.stage5DiceImageRUIDs2[roll2]
					end
				end
			end
		end
	end
