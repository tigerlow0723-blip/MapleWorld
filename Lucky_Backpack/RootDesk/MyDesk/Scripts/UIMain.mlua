	method void UpdateStage5SuccessFailRoll()
		if self.gameManager == nil or self.gameManager.miniGameManager == nil then
			return
		end
		local roll = tonumber(self.gameManager.miniGameManager.lastDiceRoll) or 0
		local roll2 = tonumber(self.gameManager.miniGameManager.lastDiceRoll2) or 0
		local didWin = (self.gameManager.miniGameManager.lastRoundWin == true)
		local resultKey = tostring(roll) .. ":" .. tostring(roll2) .. ":" .. (didWin and "W" or "L")
		if self.stage5ResultRollKey ~= resultKey then
			self.stage5ResultRollKey = resultKey
			self.stage5ResultRollPlayed = false
		end
		
		-- During success/fail roll phase, force dice to static images.
		if self.stage5DiceRollEntity ~= nil then
			self.stage5DiceRollEntity.Enable = false
		end
		if self.stage5DiceRollEntity2 ~= nil then
			self.stage5DiceRollEntity2.Enable = false
		end
		if self.stage5DiceImageEntity ~= nil then
			if self.stage5DiceImageRUIDs ~= nil and roll >= 1 and roll <= 7 and self.stage5DiceImageRUIDs[roll] ~= nil and self.stage5DiceImageRUIDs[roll] ~= "" then
				local gui = self.stage5DiceImageEntity.SpriteGUIRendererComponent
				if gui ~= nil then
					gui.ImageRUID = self.stage5DiceImageRUIDs[roll]
				else
					local sprite = self.stage5DiceImageEntity.SpriteRendererComponent
					if sprite ~= nil then
						sprite.SpriteRUID = self.stage5DiceImageRUIDs[roll]
					end
				end
				self.stage5DiceImageEntity.Enable = true
			else
				self.stage5DiceImageEntity.Enable = false
			end
		end
		if self.stage5DiceImageEntity2 ~= nil then
			if self.stage5DiceImageRUIDs2 ~= nil and roll2 >= 1 and roll2 <= 7 and self.stage5DiceImageRUIDs2[roll2] ~= nil and self.stage5DiceImageRUIDs2[roll2] ~= "" then
				local gui2 = self.stage5DiceImageEntity2.SpriteGUIRendererComponent
				if gui2 ~= nil then
					gui2.ImageRUID = self.stage5DiceImageRUIDs2[roll2]
				else
					local sprite2 = self.stage5DiceImageEntity2.SpriteRendererComponent
					if sprite2 ~= nil then
						sprite2.SpriteRUID = self.stage5DiceImageRUIDs2[roll2]
					end
				end
				self.stage5DiceImageEntity2.Enable = true
			else
				self.stage5DiceImageEntity2.Enable = false
			end
		end
		
		if self.uiStage5_Success ~= nil then
			self.uiStage5_Success.Enable = false
		end
		if self.uiStage5_Fail ~= nil then
			self.uiStage5_Fail.Enable = false
		end
		
		local dm = nil
		if self.gameManager ~= nil and self.gameManager.dataManager ~= nil then
			dm = self.gameManager.dataManager
		end
		
		if didWin == true then
			if self.uiStage5_SuccessRoll ~= nil then
				self.uiStage5_SuccessRoll.Enable = true
				if self.stage5ResultRollPlayed == false and dm ~= nil and dm.SuccessAnimRUID ~= nil and dm.SuccessAnimRUID ~= "" then
					local gui = self.uiStage5_SuccessRoll.SpriteGUIRendererComponent
					if gui ~= nil then
						gui.Enable = false
						gui.AnimClipPlayType = SpriteAnimClipPlayType.Onetime
						gui.StartFrameIndex = 0
						gui.PlayRate = 1
						gui.ImageRUID = dm.SuccessAnimRUID
						gui.Enable = true
					else
						local sprite = self.uiStage5_SuccessRoll.SpriteRendererComponent
						if sprite ~= nil then
							sprite.Enable = false
							sprite.PlayRate = 1
							sprite.StartFrameIndex = 0
							sprite.SpriteRUID = dm.SuccessAnimRUID
							sprite.Enable = true
						end
					end
				end
			end
			if self.uiStage5_FailRoll ~= nil then
				self.uiStage5_FailRoll.Enable = false
			end
		else
			if self.uiStage5_FailRoll ~= nil then
				self.uiStage5_FailRoll.Enable = true
				if self.stage5ResultRollPlayed == false and dm ~= nil and dm.FailAnimRUID ~= nil and dm.FailAnimRUID ~= "" then
					local gui = self.uiStage5_FailRoll.SpriteGUIRendererComponent
					if gui ~= nil then
						gui.Enable = false
						gui.AnimClipPlayType = SpriteAnimClipPlayType.Onetime
						gui.StartFrameIndex = 0
						gui.PlayRate = 1
						gui.ImageRUID = dm.FailAnimRUID
						gui.Enable = true
					else
						local sprite = self.uiStage5_FailRoll.SpriteRendererComponent
						if sprite ~= nil then
							sprite.Enable = false
							sprite.PlayRate = 1
							sprite.StartFrameIndex = 0
							sprite.SpriteRUID = dm.FailAnimRUID
							sprite.Enable = true
						end
					end
				end
			end
			if self.uiStage5_SuccessRoll ~= nil then
				self.uiStage5_SuccessRoll.Enable = false
			end
		end
		self.stage5ResultRollPlayed = true
	end

	method void UpdateStage5DiceResult()
		if self.gameManager == nil or self.gameManager.miniGameManager == nil then
			return
		end
		if self.stage5DiceRollEntity ~= nil then
			self.stage5DiceRollEntity.Enable = false
		end
		if self.stage5DiceRollEntity2 ~= nil then
			self.stage5DiceRollEntity2.Enable = false
		end
		if self.stage5DiceImageEntity == nil and self.stage5DiceImageEntity2 == nil then
			return
		end
		
		local roll = tonumber(self.gameManager.miniGameManager.lastDiceRoll) or 0
		local roll2 = tonumber(self.gameManager.miniGameManager.lastDiceRoll2) or 0
		if roll < 1 or roll > 7 then
			return
		end
		if roll2 < 1 or roll2 > 7 then
			return
		end
		
		if self.stage5DiceImageEntity ~= nil then
			self.stage5DiceImageEntity.Enable = true
			if self.stage5DiceImageRUIDs ~= nil and self.stage5DiceImageRUIDs[roll] ~= nil and self.stage5DiceImageRUIDs[roll] ~= "" then
				local gui = self.stage5DiceImageEntity.SpriteGUIRendererComponent
				if gui ~= nil then
					gui.ImageRUID = self.stage5DiceImageRUIDs[roll]
				else
					local sprite = self.stage5DiceImageEntity.SpriteRendererComponent
					if sprite ~= nil then
						sprite.SpriteRUID = self.stage5DiceImageRUIDs[roll]
					end
				end
			end
		end
		
		if self.stage5DiceImageEntity2 ~= nil then
			self.stage5DiceImageEntity2.Enable = true
			if self.stage5DiceImageRUIDs2 ~= nil and self.stage5DiceImageRUIDs2[roll2] ~= nil and self.stage5DiceImageRUIDs2[roll2] ~= "" then
				local gui2 = self.stage5DiceImageEntity2.SpriteGUIRendererComponent
				if gui2 ~= nil then
					gui2.ImageRUID = self.stage5DiceImageRUIDs2[roll2]
				else
					local sprite2 = self.stage5DiceImageEntity2.SpriteRendererComponent
					if sprite2 ~= nil then
						sprite2.SpriteRUID = self.stage5DiceImageRUIDs2[roll2]
					end
				end
			end
		end
		
		if self.uiStage5_Success ~= nil then
			self.uiStage5_Success.Enable = false
		end
		if self.uiStage5_Fail ~= nil then
			self.uiStage5_Fail.Enable = false
		end
		if self.uiStage5_SuccessRoll ~= nil then
			self.uiStage5_SuccessRoll.Enable = false
		end
		if self.uiStage5_FailRoll ~= nil then
			self.uiStage5_FailRoll.Enable = false
		end
		
		if self.gameManager.miniGameManager.lastRoundWin == true then
			if self.uiStage5_Success ~= nil then
				self.uiStage5_Success.Enable = true
				local dm = nil
				if self.gameManager ~= nil and self.gameManager.dataManager ~= nil then
					dm = self.gameManager.dataManager
				end
				if dm ~= nil and dm.SuccessImgRUID ~= nil and dm.SuccessImgRUID ~= "" then
					local gui = self.uiStage5_Success.SpriteGUIRendererComponent
					if gui ~= nil then
						gui.ImageRUID = dm.SuccessImgRUID
					end
				end
			end
		else
			if self.uiStage5_Fail ~= nil then
				self.uiStage5_Fail.Enable = true
				local dm = nil
				if self.gameManager ~= nil and self.gameManager.dataManager ~= nil then
					dm = self.gameManager.dataManager
				end
				if dm ~= nil and dm.FailImgRUID ~= nil and dm.FailImgRUID ~= "" then
					local gui = self.uiStage5_Fail.SpriteGUIRendererComponent
					if gui ~= nil then
						gui.ImageRUID = dm.FailImgRUID
					end
				end
			end
		end
	end

