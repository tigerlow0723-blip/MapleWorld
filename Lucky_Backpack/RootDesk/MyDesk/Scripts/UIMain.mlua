	end

	method void UpdateMonsterHPBars()
		if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
			local monsterMgr = self.battleManager.monsterManager
			if not monsterMgr.isBossBattle then
				for i, monster in ipairs(monsterMgr.monsterList) do
					if monster.alive and monster.entityId ~= nil then
						local mEntity = _EntityService:GetEntity(monster.entityId)
						if mEntity ~= nil then
							local mSlider = self.monsterSliders[i]
							if mSlider == nil or not _EntityService:IsValid(mSlider) then
								if self.sliderHP ~= nil then
									mSlider = _SpawnService:SpawnByEntity(self.sliderHP, "MonsterSlider_"..i, Vector3.zero, self.sliderHP.Parent)
									if mSlider ~= nil then
																				self.monsterSliders[i] = mSlider
										local canvas = mSlider.CanvasGroupComponent
										if canvas == nil then
											canvas = mSlider:AddComponent("CanvasGroupComponent")
										end
										if canvas ~= nil then
											canvas.Interactable = false
										end
										local uiTrans = mSlider.UITransformComponent
										if uiTrans ~= nil then
											uiTrans.RectSize = Vector2(100, 30)
										end
									end
								end
							end
							
							if mSlider ~= nil then
								mSlider.Enable = true
								local sliderComp = mSlider.SliderComponent
								if sliderComp ~= nil then
									local ratio = 0
									if monster.maxHP > 0 then ratio = monster.currentHP / monster.maxHP end
									if ratio < 0 then ratio = 0 end
									if ratio > 1 then ratio = 1 end
									sliderComp.Value = ratio
								end
								
								local txtComp = mSlider.TextComponent
								if txtComp == nil then
									local textComps = mSlider:GetChildComponentsByTypeName("TextComponent", true)
									if textComps ~= nil and #textComps > 0 then
										txtComp = textComps[1]
									end
								end
								if txtComp ~= nil then
									local displayHP = math.ceil(math.max(0, tonumber(monster.currentHP) or 0))
									txtComp.Text = tostring(displayHP)
								end
								
								local mAtkText = self.monsterAtkTexts[i]
								if mAtkText == nil or not _EntityService:IsValid(mAtkText) then
									local atkTemplate = nil
									if self.sliderHP ~= nil then
										atkTemplate = self.sliderHP:GetChildByName("UIText")
									end
									if atkTemplate ~= nil and self.sliderHP ~= nil then
										mAtkText = _SpawnService:SpawnByEntity(atkTemplate, "MonsterAtkText_"..i, Vector3.zero, self.sliderHP.Parent)
										if mAtkText ~= nil then
											self.monsterAtkTexts[i] = mAtkText
											local atkCanvas = mAtkText.CanvasGroupComponent
											if atkCanvas == nil then
												atkCanvas = mAtkText:AddComponent("CanvasGroupComponent")
											end
											if atkCanvas ~= nil then
												atkCanvas.Interactable = false
											end
											local atkUI = mAtkText.UITransformComponent
											if atkUI ~= nil then
												atkUI.RectSize = Vector2(130, 24)
											end
											local atkSprite = mAtkText.SpriteGUIRendererComponent
											if atkSprite ~= nil then
												atkSprite.Enable = false
											end
										end
									end
								end
								
								local hasAtkIcon = false
								local atkIconRuid = tostring(self.monsterAtkIconRUID or "")
								atkIconRuid = string.gsub(atkIconRuid, "^%s+", "")
								atkIconRuid = string.gsub(atkIconRuid, "%s+$", "")
								if atkIconRuid ~= "" and string.upper(atkIconRuid) ~= "NONE" then
									hasAtkIcon = true
								end
								
								local mAtkIcon = self.monsterAtkIcons[i]
								if hasAtkIcon then
									if mAtkIcon == nil or not _EntityService:IsValid(mAtkIcon) then
										local atkIconTemplate = nil
										if self.sliderHP ~= nil then
											atkIconTemplate = self.sliderHP
										end
										if atkIconTemplate ~= nil and self.sliderHP ~= nil then
											mAtkIcon = _SpawnService:SpawnByEntity(atkIconTemplate, "MonsterAtkIcon_"..i, Vector3.zero, self.sliderHP.Parent)
											if mAtkIcon ~= nil then
												self.monsterAtkIcons[i] = mAtkIcon
												local iconCanvas = mAtkIcon.CanvasGroupComponent
												if iconCanvas == nil then
													iconCanvas = mAtkIcon:AddComponent("CanvasGroupComponent")
												end
												if iconCanvas ~= nil then
													iconCanvas.Interactable = false
												end
												local iconUI = mAtkIcon.UITransformComponent
												if iconUI ~= nil then
													local iconSize = tonumber(self.monsterAtkIconSize) or 18
													if iconSize < 1 then
														iconSize = 18
													end
													iconUI.RectSize = Vector2(iconSize, iconSize)
												end
												local iconSlider = mAtkIcon.SliderComponent
												if iconSlider ~= nil then
													iconSlider.Enable = false
												end
												local iconTextComps = mAtkIcon:GetChildComponentsByTypeName("TextComponent", true)
												if iconTextComps ~= nil then
													for t = 1, #iconTextComps do
														local tc = iconTextComps[t]
														if tc ~= nil then
															tc.Text = ""
														end
													end
												end
											end
										end
									end
									
									if mAtkIcon ~= nil and _EntityService:IsValid(mAtkIcon) then
										local iconSprite = mAtkIcon.SpriteGUIRendererComponent
										if iconSprite ~= nil then
											pcall(function() iconSprite.Type = 1 end)
											iconSprite.Color = Color(1, 1, 1, 1)
											if tostring(iconSprite.ImageRUID or "") ~= atkIconRuid then
												iconSprite.ImageRUID = atkIconRuid
											end
											iconSprite.Enable = true
											mAtkIcon.Enable = true
										else
											mAtkIcon.Enable = false
										end
									end
								else
									if mAtkIcon ~= nil and _EntityService:IsValid(mAtkIcon) then
										local iconSprite = mAtkIcon.SpriteGUIRendererComponent
										if iconSprite ~= nil then
											iconSprite.Enable = false
										end
										mAtkIcon.Enable = false
									end
								end
								
								if mAtkText ~= nil then
									mAtkText.Enable = true
									local atkTextComp = mAtkText.TextComponent
									if atkTextComp ~= nil then
										atkTextComp.FontColor = Color(1, 0, 0, 1)
										local displayATK = math.ceil(math.max(0, tonumber(monster.atk) or 0))
										local displayATKText = tostring(displayATK)

										local plannedResolved = false
										local turnKey = ""
										if self.battleManager ~= nil then
											turnKey = string.lower(tostring(self.battleManager.currentTurn or ""))
											turnKey = string.gsub(turnKey, "^%s+", "")
											turnKey = string.gsub(turnKey, "%s+$", "")
										end
										
										if turnKey == "player" and monster.plannedActionReady == true then
											local plannedStatus = string.lower(tostring(monster.plannedStatus or ""))
											plannedStatus = string.gsub(plannedStatus, "^%s+", "")
											plannedStatus = string.gsub(plannedStatus, "%s+$", "")
											
											local plannedHitCount = math.floor(tonumber(monster.plannedHitCount) or 1)
											if plannedStatus == "multi" and plannedHitCount > 1 then
												displayATKText = tostring(displayATK) .. "x" .. tostring(plannedHitCount)
											else
												displayATKText = tostring(displayATK)
											end
											plannedResolved = true
										end
										
										if plannedResolved ~= true then
											local patternKey = string.lower(tostring(monster.patternId or ""))
											patternKey = string.gsub(patternKey, "^%s+", "")
											patternKey = string.gsub(patternKey, "%s+$", "")
											
											local statusKey = string.lower(tostring(monster.status or ""))
											statusKey = string.gsub(statusKey, "^%s+", "")
											statusKey = string.gsub(statusKey, "%s+$", "")
											
											local isMultiPattern = (patternKey == "multi" or statusKey == "multi")
											local multiHitCount = math.floor(tonumber(monster.atkCount) or 0)
											if isMultiPattern and multiHitCount > 1 then
												local patternProb = tonumber(monster.patternProb) or 0
												if patternProb < 0 then
													patternProb = 0
												elseif patternProb > 100 then
													patternProb = 100
												end
												
												if patternProb >= 100 then
													displayATKText = tostring(displayATK) .. "x" .. tostring(multiHitCount)
												elseif patternProb > 0 then
													local probText = tostring(math.floor(patternProb + 0.5))
													displayATKText = tostring(displayATK) .. "x" .. tostring(multiHitCount) .. "(" .. probText .. "%)"
												end
											end
										end
										
										if hasAtkIcon then
											atkTextComp.Text = displayATKText
										else
											local fallbackPrefix = tostring(self.monsterAtkFallbackPrefix or "")
											fallbackPrefix = string.gsub(fallbackPrefix, "^%s+", "")
											fallbackPrefix = string.gsub(fallbackPrefix, "%s+$", "")
											if fallbackPrefix == "" then
												fallbackPrefix = "ATK"
											end
											atkTextComp.Text = fallbackPrefix .. " " .. displayATKText
										end
									end
								end
								
								local uiTrans = mSlider.UITransformComponent
								if uiTrans ~= nil then
									local mTrans = mEntity.TransformComponent
									if mTrans ~= nil then
										local mPos = mTrans.Position
										local parentUI = nil
										if mSlider.Parent ~= nil then parentUI = mSlider.Parent.UITransformComponent end
										if parentUI ~= nil then
											local screenPos = _UILogic:WorldToScreenPosition(Vector2(mPos.x, mPos.y - 0.5))
											local sliderLocalPos = _UILogic:ScreenToLocalUIPosition(screenPos, parentUI)
											uiTrans.anchoredPosition = sliderLocalPos
											
											local arrowOffset = tonumber(monster.arrowOffsetY) or 1.2
											local belowTargetOffset = tonumber(self.monsterAtkBelowTargetWorldOffset) or 0.25
											if belowTargetOffset < 0 then
												belowTargetOffset = -belowTargetOffset
											end
											local targetWorldY = mPos.y + arrowOffset
											local atkWorldY = targetWorldY - belowTargetOffset
											local atkScreenPos = _UILogic:WorldToScreenPosition(Vector2(mPos.x, atkWorldY))
											local atkLocalPos = _UILogic:ScreenToLocalUIPosition(atkScreenPos, parentUI)
											local atkOffsetY = tonumber(self.monsterAtkOffsetY) or 0
											
											if mAtkText ~= nil and _EntityService:IsValid(mAtkText) then
												local atkUI = mAtkText.UITransformComponent
												if atkUI ~= nil then
													local textOffsetX = 0
													if hasAtkIcon then
														textOffsetX = tonumber(self.monsterAtkTextOffsetX) or 0
													end
													atkUI.anchoredPosition = Vector2(atkLocalPos.x + textOffsetX, atkLocalPos.y + atkOffsetY)
												end
											end
											
											if hasAtkIcon and mAtkIcon ~= nil and _EntityService:IsValid(mAtkIcon) then
												local iconUI = mAtkIcon.UITransformComponent
												if iconUI ~= nil then
													local iconOffsetX = tonumber(self.monsterAtkIconOffsetX) or -14
													iconUI.anchoredPosition = Vector2(atkLocalPos.x + iconOffsetX, atkLocalPos.y + atkOffsetY)
												end
											end
										end
									end
								end
							end
						end
					else
						local mSlider = self.monsterSliders[i]
						if mSlider ~= nil and _EntityService:IsValid(mSlider) then
							mSlider.Enable = false
							mSlider:Destroy()
						end
						self.monsterSliders[i] = nil
						
						local mAtkText = self.monsterAtkTexts[i]
						if mAtkText ~= nil and _EntityService:IsValid(mAtkText) then
							mAtkText.Enable = false
							mAtkText:Destroy()
						end
						self.monsterAtkTexts[i] = nil
						
						local mAtkIcon = self.monsterAtkIcons[i]
						if mAtkIcon ~= nil and _EntityService:IsValid(mAtkIcon) then
							mAtkIcon.Enable = false
							mAtkIcon:Destroy()
						end
						self.monsterAtkIcons[i] = nil
					end
				end
			end
			
			-- Clean up old sliders
			for i, mSlider in pairs(self.monsterSliders) do
				if monsterMgr.isBossBattle or i > #monsterMgr.monsterList then
					if mSlider ~= nil and _EntityService:IsValid(mSlider) then
						mSlider.Enable = false
						mSlider:Destroy()
					end
					self.monsterSliders[i] = nil
					
					local mAtkText = self.monsterAtkTexts[i]
					if mAtkText ~= nil and _EntityService:IsValid(mAtkText) then
						mAtkText.Enable = false
						mAtkText:Destroy()
					end
					self.monsterAtkTexts[i] = nil
					
					local mAtkIcon = self.monsterAtkIcons[i]
					if mAtkIcon ~= nil and _EntityService:IsValid(mAtkIcon) then
						mAtkIcon.Enable = false
						mAtkIcon:Destroy()
					end
					self.monsterAtkIcons[i] = nil
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateTargetIndicatorPosition(Entity indicator, Vector3 worldPos, boolean visible)
		if indicator == nil then
			return
		end
		
		if visible ~= true then
			indicator.Enable = false
			return
		end
		
		indicator.Enable = true
		
		local uiTransform = indicator.UITransformComponent
		if uiTransform ~= nil then
			local parent = indicator.Parent
			local parentUI = nil
			if parent ~= nil then
				parentUI = parent.UITransformComponent
			end
			
			if parentUI ~= nil then
				local screenPos = _UILogic:WorldToScreenPosition(Vector2(worldPos.x, worldPos.y))
				uiTransform.anchoredPosition = _UILogic:ScreenToLocalUIPosition(screenPos, parentUI)
				return
			end
		end
		
		local worldTransform = indicator.TransformComponent
		if worldTransform ~= nil then
			worldTransform.Position = worldPos
		end
	end
	
	method void RestartBossSkillSprite(Entity targetEntity, boolean loopPlay)
		if targetEntity == nil then
			return
		end
		
		local gui = targetEntity.SpriteGUIRendererComponent
		if gui ~= nil then
			local currentRuid = gui.ImageRUID
			gui.Enable = false
			gui.PlayRate = 1
			gui.StartFrameIndex = 0
			if loopPlay == true then
				gui.AnimClipPlayType = SpriteAnimClipPlayType.Loop
			else
				gui.AnimClipPlayType = SpriteAnimClipPlayType.Onetime
			end
			
			if currentRuid ~= nil and tostring(currentRuid) ~= "" then
				gui.ImageRUID = ""
				gui.ImageRUID = currentRuid
			else
				gui.ImageRUID = currentRuid
			end
			gui.Enable = true
			return
		end
		
		local sprite = targetEntity.SpriteRendererComponent
		if sprite ~= nil then
			local currentRuid = sprite.SpriteRUID
			sprite.Enable = false
			sprite.PlayRate = 1
			sprite.StartFrameIndex = 0
			if currentRuid ~= nil and tostring(currentRuid) ~= "" then
				sprite.SpriteRUID = ""
				sprite.SpriteRUID = currentRuid
			else
				sprite.SpriteRUID = currentRuid
			end
			sprite.Enable = true
		end
	end

	method void UpdateBossSkillUI(string selectedType, number duration)
		-- 기�???????��????��??(???��??경�??
		if self.shieldTimer ~= nil then
			_TimerService:ClearTimer(self.shieldTimer)
			self.shieldTimer = nil
		end
		if self.skill1Timer ~= nil then
			_TimerService:ClearTimer(self.skill1Timer)
			self.skill1Timer = nil
		end
		
		if self.uiBossSkill1Sub == nil and self.uiBossSkill1 ~= nil then
			self.uiBossSkill1Sub = self.uiBossSkill1:GetChildByName("UISprite", true)
		end
		
		local normalizedType = tostring(selectedType or "")
		normalizedType = string.gsub(normalizedType, "^%s+", "")
		normalizedType = string.gsub(normalizedType, "%s+$", "")
		normalizedType = string.lower(normalizedType)
		
		-- Keep parent sprite state deterministic every time this UI opens.
		if self.uiBossSkill1 ~= nil then
			local parentImg = self.uiBossSkill1.SpriteGUIRendererComponent
			if parentImg ~= nil then
				parentImg.Enable = true
				parentImg.Color = Color(1, 1, 1, 1)
			end
		end
		
		local animDuration = duration
		if animDuration == nil or animDuration <= 0 then
			if normalizedType == "shield" then
				animDuration = 0.81
			else
				animDuration = 1.5
			end
		end
		
		local skills = {
			{entity = self.uiBossSkill1, skillType = "hp_dmg"},
			{entity = self.uiBossSkill2, skillType = "poison"},
			{entity = self.uiBossSkill4, skillType = "heal"}
		}
		
		for i = 1, #skills do
			local skill = skills[i]
			if skill.entity ~= nil then
				local img = skill.entity.SpriteGUIRendererComponent
				if img ~= nil then
					if skill.skillType == normalizedType then
						-- Show and highlight only the selected skill
						skill.entity.Enable = true
						img.Color = Color(1, 1, 1, 1)
					else
						-- Hide all other skills completely
						skill.entity.Enable = false
					end
				end
			end
		end
		
		-- Skill1: play parent first, then child entity.
		if normalizedType == "hp_dmg" then
			if self.uiBossSkill1Sub ~= nil then
				self.uiBossSkill1Sub.Enable = false
			end
			
			local parentDuration = tonumber(self.bossSkill1ParentDurationOverride) or -1
			if parentDuration > 0 then
				self.bossSkill1ParentDurationOverride = -1
			else
				parentDuration = tonumber(self.bossSkill1ParentDuration) or 0
			end
			if parentDuration <= 0 then
				parentDuration = animDuration * 0.5
			end
			if parentDuration < 0 then
				parentDuration = 0
			end
			if parentDuration > animDuration then
				parentDuration = animDuration
			end
			
			self.skill1Timer = _TimerService:SetTimerOnce(function()
				self.skill1Timer = nil
				if self.uiBossSkill1 ~= nil then
					-- Keep parent entity enabled: sub sprite is its child.
					local parentImg = self.uiBossSkill1.SpriteGUIRendererComponent
					if parentImg ~= nil then
						parentImg.Enable = false
					end
				end
				if self.uiBossSkill1Sub ~= nil then
					self.uiBossSkill1Sub.Enable = true
					local subImg = self.uiBossSkill1Sub.SpriteGUIRendererComponent
					if subImg ~= nil then
						subImg.Color = Color(1, 1, 1, 1)
					end
				end
			end, parentDuration)
		else
			if self.uiBossSkill1 ~= nil then
				local parentImg = self.uiBossSkill1.SpriteGUIRendererComponent
				if parentImg ~= nil then
					parentImg.Enable = true
				end
			end
			if self.uiBossSkill1Sub ~= nil then
				self.uiBossSkill1Sub.Enable = false
			end
		end
		
		-- ???��????????????��??처�??(1.53?????��????반�???????????��?????????
		if normalizedType == "shield" then
			if self.uiBossSkill1Sub ~= nil then self.uiBossSkill1Sub.Enable = false end
			if self.uiBossSkill3 ~= nil then
				self:RestartBossSkillSprite(self.uiBossSkill3, false)
				self.uiBossSkill3.Enable = true
				local img = self.uiBossSkill3.SpriteGUIRendererComponent
				if img ~= nil then img.Color = Color(1, 1, 1, 1) end
			end
			if self.uiBossSkill3_1 ~= nil then
				self.uiBossSkill3_1.Enable = false
			end
			
			local switchFunc = function()
				self.shieldTimer = nil
				if self.uiBossSkill3 ~= nil then
					self.uiBossSkill3.Enable = false
				end
				if self.uiBossSkill3_1 ~= nil then
					self:RestartBossSkillSprite(self.uiBossSkill3_1, true)
					self.uiBossSkill3_1.Enable = true
					local loopImg = self.uiBossSkill3_1.SpriteGUIRendererComponent
					if loopImg ~= nil then loopImg.Color = Color(1, 1, 1, 1) end
				end
			end
			self.shieldTimer = _TimerService:SetTimerOnce(switchFunc, animDuration)
		else
			if self.uiBossSkill3 ~= nil then self.uiBossSkill3.Enable = false end
			
			-- ???��????????????��?????��???보�????��?????�드�? ???��????��??�????��?????��?? ?????????��?? ???��?? ???��??
			local hasShield = false
			if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
				local monsterMgr = self.battleManager.monsterManager
				if monsterMgr.isBossBattle and #monsterMgr.monsterList > 0 then
					local boss = monsterMgr.monsterList[1]
					if boss ~= nil and boss.isBoss and boss.alive and boss.shieldActive == true then
						hasShield = true
					end
				end
			end
			
			if not hasShield then
				if self.uiBossSkill3_1 ~= nil then self.uiBossSkill3_1.Enable = false end
			end
		
			-- ???�드�? ???��?????��??????????????��?????��????????��??�????��??처�??(???????????��???duration ???��??
			local hideOtherSkillFunc = function()
				self.shieldTimer = nil
				local entities = {self.uiBossSkill1, self.uiBossSkill1Sub, self.uiBossSkill2, self.uiBossSkill4}
				for j = 1, #entities do
					if entities[j] ~= nil then
						entities[j].Enable = false
					end
				end
			end
			self.shieldTimer = _TimerService:SetTimerOnce(hideOtherSkillFunc, animDuration)
		end
		
		log("[UIMain] Boss skill highlighted: " .. tostring(normalizedType))
	end

	method void ResetBossSkillUI()
		if self.skill1Timer ~= nil then
			_TimerService:ClearTimer(self.skill1Timer)
			self.skill1Timer = nil
		end
		
		local hasShield = false
		if self.battleManager ~= nil and self.battleManager.monsterManager ~= nil then
			local monsterMgr = self.battleManager.monsterManager
			if monsterMgr.isBossBattle and #monsterMgr.monsterList > 0 then
				local boss = monsterMgr.monsterList[1]
				if boss ~= nil and boss.isBoss and boss.alive and boss.shieldActive == true then
					hasShield = true
				end
			end
		end
		
		if not hasShield then
			if self.shieldTimer ~= nil then
				_TimerService:ClearTimer(self.shieldTimer)
				self.shieldTimer = nil
			end
			if self.uiBossSkill3 ~= nil then self.uiBossSkill3.Enable = false end
			if self.uiBossSkill3_1 ~= nil then self.uiBossSkill3_1.Enable = false end
		end
		
		local entities = {self.uiBossSkill1, self.uiBossSkill2, self.uiBossSkill4}
		for i = 1, #entities do
			if entities[i] ~= nil then
				-- Hide all skill icons completely when boss is not using a skill
				entities[i].Enable = false
			end
		end
		if self.uiBossSkill1Sub ~= nil then
			self.uiBossSkill1Sub.Enable = false
		end
		
		self:RefreshBossPoisonDotFX()
	end

	method void SetBossSkillUIEnable(boolean enable)
		local entities = {self.uiBossSkill1, self.uiBossSkill1Sub, self.uiBossSkill2, self.uiBossSkill3, self.uiBossSkill3_1, self.uiBossSkill4}
		for i = 1, #entities do
			if entities[i] ~= nil then
				entities[i].Enable = enable
			end
		end
	end

	method void ShowClearUI()
		self:ResolveClearUI()
		if self.uiClear ~= nil then
			self.uiClear.Enable = true
			self.uiClear:SetVisible(true)
		end
	end

	method void HideClearUI()
		if self.uiClear ~= nil then
			self.uiClear.Enable = false
			self.uiClear:SetVisible(false)
		end
	end

	method void ShowFailUI()
		self:ResolveFailUI()
		if self.uiFail ~= nil then
			self.uiFail.Enable = true
			self.uiFail:SetVisible(true)
		end
	end

	method void HideFailUI()
		if self.uiFail ~= nil then
			self.uiFail.Enable = false
			self.uiFail:SetVisible(false)
		end
	end

	method void ShowNoOreWarning()
		local warningEntity = _EntityService:GetEntityByPath("/ui/UIGroup/UI_NoOreWarning")
		if warningEntity == nil then
			warningEntity = _EntityService:GetEntityByPath("/ui/UIGroup/NoOreWarning")
		end
		
		if warningEntity ~= nil then
			warningEntity.Enable = true
			if warningEntity.UITransformComponent ~= nil then
				warningEntity:SetVisible(true)
			end
			
			-- Hide after 2 seconds
			_TimerService:SetTimerOnce(function()
				if _EntityService:IsValid(warningEntity) then
					warningEntity.Enable = false
					if warningEntity.UITransformComponent ~= nil then
						warningEntity:SetVisible(false)
					end
				end
			end, 2.0)
		else
			log_warning("[UIMain] ShowNoOreWarning called, but UI_NoOreWarning entity not found in /ui/UIGroup/")
		end
	end

end
