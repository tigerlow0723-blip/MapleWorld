@Component
script MonsterManager extends Component

	property table monsterList = {}

	property boolean isBossBattle = false

	property string currentBossId = ""

	property Entity bossSpawnPoint = nil

	property Entity monsterSpawnArea = nil

	property integer currentBossPhase = 1

	property any dataManager = nil

	property string modelId = "model://maplestorymonster$17d15ed30cb74b25a3542fa71fb5b849"

	property number spawnEntranceOffsetX = 2.2

	property number spawnEntranceDuration = 1

	property integer spawnEntranceSteps = 95

	property Entity targetIndicator = nil

	property string targetIndicatorPath = "/ui/UIGroup/TargetIndicator"

	property string targetIndicatorImageRUID = ""
	
	property string targetIndicatorBoundRUID = ""
	
	property boolean targetIndicatorWasVisible = false

	property number lastDamage = 0

	property integer lastHitCount = 1

	property string lastStatus = "none"

	property number lastDotDmg = 0

	property integer lastDotTurn = 0

	property number lastPatternDuration = 1.5

	property number bossSkillImpactDelay = 1.75

	property boolean lastActionValid = false

	property integer lastRewardExp = 0

	property integer lastRewardGold = 0

	property any uiMain = nil

	property integer pendingSpawnEntranceCount = 0
	
	property boolean isPhaseTransitioning = false
	
	property boolean isDyingAnimating = false

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		log("[MonsterManager] Initialized.")
	end

	method void SpawnMonsters(integer stageId, any dataMgr)
		self.dataManager = dataMgr
		self.monsterList = {}
		self.isBossBattle = false
		self.pendingSpawnEntranceCount = 0
		self.isPhaseTransitioning = false
		self.isDyingAnimating = false
		
		local spawnInfo = dataMgr:GetSpawnInfo(stageId)
		if spawnInfo == nil then
			log_error("[MonsterManager] " .. tostring(stageId))
			return
		end
		
		local spawnTemplates = {}
		local exactSpawns = spawnInfo.exactSpawns or ""
		
		if exactSpawns ~= "" then
			local parts = _UtilLogic:Split(exactSpawns, "/")
			for p = 1, #parts do
				local part = parts[p]
				local subParts = _UtilLogic:Split(part, ":")
				if #subParts >= 2 then
					local mId = subParts[1]
					local mCount = tonumber(subParts[2]) or 1
					local mData = dataMgr:GetMonsterData(mId)
					if mData ~= nil then
						for c = 1, mCount do
							spawnTemplates[#spawnTemplates + 1] = mData
						end
					else
						log_error("[MonsterManager] Cannot find exact monster ID: " .. tostring(mId))
					end
				end
			end
		end
		
		local minMon = spawnInfo.minMonsters or 0
		local maxMon = spawnInfo.maxMonsters or 0
		local poolId = spawnInfo.poolId or 0
		if minMon > 0 and maxMon > 0 and poolId > 0 then
			local poolMonsters = dataMgr:GetMonstersByPool(poolId)
			if #poolMonsters > 0 then
				local randomCount = math.random(minMon, maxMon)
				for i = 1, randomCount do
					local idx = math.random(1, #poolMonsters)
					spawnTemplates[#spawnTemplates + 1] = poolMonsters[idx]
				end
			end
		end
		
		if #spawnTemplates == 0 then
			log_error("[MonsterManager] No monsters to spawn for stage: " .. tostring(stageId))
			return
		end
		
		local count = #spawnTemplates
		log("[MonsterManager] Spawn count: " .. tostring(count) .. " (stage group: " .. tostring(stageId) .. ")")
		
		for i = 1, count do
			local template = spawnTemplates[i]
		
			--
			local monster = {}
			monster.id = template.id
			monster.name = template.name .. " #" .. tostring(i)
			monster.maxHP = template.hp
			monster.currentHP = template.hp
			monster.atk = template.atk
			monster.def = template.def
			monster.dodge = template.dodge
			monster.patternId = template.patternId
			monster.patternProb = template.patternProb
			monster.atkCount = template.atkCount
			monster.status = template.status
			monster.dotDmg = template.dotDmg
			monster.dotTurn = template.dotTurn
			monster.rewardExp = template.rewardExp
			monster.rewardGold = template.goldDrop or template.rewardGold or 0
			monster.modelID = template.modelID or ""
			monster.alive = true
			monster.deathDelay = template.deathDelay or 0.7
			monster.arrowOffsetY = template.arrowOffsetY or 1.2
			monster.attackDelay = tonumber(template.attackDelay) or 1.0
			if monster.attackDelay < 0 then
				monster.attackDelay = 0
			end
			monster.dotEffects = {}
			monster.incomingDmgUp = 0
			monster.incomingDmgUpTurn = 0
		
			self.monsterList[#self.monsterList + 1] = monster
			
			self:SpawnVisual(monster, i, false, count)
			log("[MonsterManager]  > " .. monster.name .. " HP:" .. tostring(monster.currentHP) .. " ATK:" .. tostring(monster.atk))
		end
	end

	method void Init(any ui)
		self.uiMain = ui
	end

	method void SpawnBoss(string bossId, any dataMgr)
		self.dataManager = dataMgr
		self.monsterList = {}
		self.isBossBattle = true
		self.currentBossId = bossId
		self.currentBossPhase = 1
		self.pendingSpawnEntranceCount = 0
		self.isPhaseTransitioning = false
		self.isDyingAnimating = false
		
		local basicData = dataMgr:GetBossBasicData(bossId)
		if basicData == nil then
			log_error("[MonsterManager] 보스 기본 ?�이?��? 찾을 ???�습?�다: " .. bossId)
			return
		end
		
		local patterns = dataMgr:GetBossPatterns(bossId, 1)
		if patterns == nil or #patterns == 0 then
			log_error("[MonsterManager] 보스 ?�턴??찾을 ???�습?�다: " .. bossId)
			return
		end
		
		local boss = {}
		boss.id = bossId
		boss.name = "Boss " .. bossId
		boss.maxHP = basicData.hpPhase1
		boss.currentHP = basicData.hpPhase1
		boss.atk = 0
		boss.def = 10
		boss.dodge = 0
		boss.alive = true
		boss.isBoss = true
		
		-- Phase HP information
		boss.hpPhase1 = basicData.hpPhase1
		boss.hpPhase2 = basicData.hpPhase2
		boss.hpPhase3 = basicData.hpPhase3
		
		-- Phase Model information
		boss.modelPhase1 = basicData.modelPhase1 or ""
		boss.modelPhase2 = basicData.modelPhase2 or ""
		boss.modelPhase3 = basicData.modelPhase3 or ""
		
		-- Phase Death Delays
		boss.deathDelayPhase1 = basicData.deathDelayPhase1 or 1.5
		boss.deathDelayPhase2 = basicData.deathDelayPhase2 or 1.5
		boss.deathDelayPhase3 = basicData.deathDelayPhase3 or 1.5
		boss.deathDelay = boss.deathDelayPhase3
		
		boss.dotEffects = {}
		boss.incomingDmgUp = 0
		boss.incomingDmgUpTurn = 0
		boss.shieldActive = false
		boss.modelID = boss.modelPhase1
		
		self.monsterList[#self.monsterList + 1] = boss
		
		self:SpawnVisual(boss, 1, true, 1)
		log("[MonsterManager] 보스 ?�폰: " .. boss.name .. " HP:" .. tostring(boss.maxHP) .. " Phase: 1")
	end

	method table DamageMonster(integer index, number damage, number accuracy, boolean isCritical)
		local monster = self.monsterList[index]
		if monster == nil or monster.alive == false then
			return nil
		end
		
		local result = {}
		result.hit = false
		result.critical = false
		result.damage = 0
		result.killed = false
		
		--
		local hitChance = accuracy - monster.dodge
		local hitRoll = math.random(1, 100)
		
		if hitRoll > hitChance then
			--
			result.hit = false
			log("[MonsterManager] " .. monster.name .. "[MonsterManager] " .. tostring(hitChance) .. "[MonsterManager] " .. tostring(hitRoll) .. ")")
			return result
		end
		
		result.hit = true
		
		-- Absolute Shield check
		if monster.isBoss and monster.shieldActive then
			result.hit = false
			result.damage = 0
			monster.shieldActive = false
			log("[MonsterManager] 보스의 절대방어가 플레이어의 공격을 막아냈습니다!")
			-- Reset shield UI effect when shield is consumed
			if self.uiMain ~= nil and self.uiMain.ResetBossSkillUI ~= nil then
				self.uiMain:ResetBossSkillUI()
			end
			return result
		end
		
		local finalDmg = math.max(1, damage - monster.def)
		if monster.incomingDmgUp ~= nil and monster.incomingDmgUp > 0 then
			finalDmg = math.floor(finalDmg * (1 + (monster.incomingDmgUp / 100.0)))
			finalDmg = math.max(1, finalDmg)
		end
		monster.currentHP -= finalDmg
		result.damage = finalDmg
		self:ProcessMonsterHitVisual(monster, finalDmg, isCritical)
		
		-- Removed NameTag HP Update
		
		log("[MonsterManager] " .. monster.name .. " took damage: " .. tostring(finalDmg) .. ", HP: " .. tostring(monster.currentHP))
		--
		local animTargetId = monster.animEntityId
		if animTargetId == nil then animTargetId = monster.entityId end
		self:PlayEntityState(animTargetId, "HIT", 1.5)
		local gameSystem = _EntityService:GetEntityByPath("/maps/map01/GameSystem")
		if gameSystem and gameSystem.SoundManager then
			local prefix = monster.isBoss and "boss_hit_" or "monster_hit_"
			local t = prefix .. tostring(monster.id)
			gameSystem.SoundManager:PlaySFXByTitle(t, 0)
		end
		
		if monster.currentHP <= 0 then
			monster.currentHP = 0
			monster.alive = false
			result.killed = true
			log("[MonsterManager] " .. monster.name .. " defeated!")
		
			-- Phase Transition
			if monster.isBoss then
				local oldEntityId = monster.entityId
				local nextPhase = self.currentBossPhase + 1
				
				if nextPhase <= 3 then
					self.currentBossPhase = nextPhase
					monster.alive = true
					
					if nextPhase == 2 then
						monster.maxHP = monster.hpPhase2
						monster.modelID = monster.modelPhase2
					elseif nextPhase == 3 then
						monster.maxHP = monster.hpPhase3
						monster.modelID = monster.modelPhase3
					end
					
					monster.currentHP = monster.maxHP
					result.killed = false
					log("[MonsterManager] 보스가 " .. tostring(nextPhase) .. "?�이즈에 ?�입?�습?�다! HP: " .. tostring(monster.maxHP))
					
					-- Destroy old model and spawn the new one
					local currentPhaseForDelay = self.currentBossPhase
					
					self.isPhaseTransitioning = true
					
					-- Play DIE animation and wait before spawning next phase
					if oldEntityId ~= nil then
						self:PlayEntityState(oldEntityId, "DIE", 0)
					end
					
					local currentDelay = monster.deathDelayPhase1
					if currentPhaseForDelay == 2 then
						currentDelay = monster.deathDelayPhase2
					end
					
					_TimerService:SetTimerOnce(function()
						if oldEntityId ~= nil then
							local oldEntity = _EntityService:GetEntity(oldEntityId)
							if oldEntity ~= nil then
								oldEntity:Destroy()
							end
						end
						
						self:SpawnVisual(monster, 1, true)
						
						_TimerService:SetTimerOnce(function()
							self.isPhaseTransitioning = false
							if self.uiMain ~= nil then
								self.uiMain:UpdateUI()
							end
						end, 1.5)
					end, currentDelay)
				else
					-- Boss Dead (Phase 3 defeated) - play die animation then destroy
					if oldEntityId ~= nil then
						self.isDyingAnimating = true
						self:PlayEntityState(oldEntityId, "DIE", 0)
						local capturedId = oldEntityId
						local delay = monster.deathDelayPhase3 or 1.5
						_TimerService:SetTimerOnce(function()
							local e = _EntityService:GetEntity(capturedId)
							if e ~= nil then
								e:Destroy()
							end
							self.isDyingAnimating = false
							if self.uiMain ~= nil then
								self.uiMain:UpdateUI()
							end
						end, delay)
						log("[MonsterManager] Boss defeated, destroying after delay: " .. oldEntityId)
					end
				end
			else
				-- Normal Monster Dead - play die animation then destroy
				local dieEntityId = monster.animEntityId or monster.entityId
				if dieEntityId ~= nil then
					self.isDyingAnimating = true
					self:PlayEntityState(dieEntityId, "DIE", 0)
					local capturedId = monster.entityId
					local delay = monster.deathDelay or 0.7
					_TimerService:SetTimerOnce(function()
						local e = _EntityService:GetEntity(capturedId)
						if e ~= nil then
							e:Destroy()
						end
						
						-- Only clear the flag if all dying animations are supposed to be done.
						-- Here we assume if it's dead, the battle ends shortly anyway.
						self.isDyingAnimating = false
						if self.uiMain ~= nil then
							self.uiMain:UpdateUI()
						end
					end, delay)
					log("[MonsterManager] Monster defeated, destroying after delay: " .. tostring(capturedId))
				end
			end
		end
		
		return result
	end


	method void ProcessMonsterHitVisual(table monster, number damage, boolean isCritical)
		if monster == nil then
			return
		end
		
		local targetEntityId = monster.animEntityId
		if targetEntityId == nil or targetEntityId == "" then
			targetEntityId = monster.entityId
		end
		if targetEntityId == nil or targetEntityId == "" then
			return
		end
		
		local targetEntity = _EntityService:GetEntity(targetEntityId)
		if targetEntity == nil then
			return
		end
		
		local hitComp = targetEntity.HitComponent
		if hitComp == nil then
			targetEntity:AddComponent("HitComponent")
			hitComp = targetEntity.HitComponent
		end
		
		-- Ensure damage skin components are present (added only once per spawn)
		if targetEntity.DamageSkinSpawnerComponent == nil then
			targetEntity:AddComponent("DamageSkinSpawnerComponent")
		end
		if targetEntity.DamageSkinSettingComponent == nil then
			targetEntity:AddComponent("DamageSkinSettingComponent")
		end
		
		if hitComp ~= nil then
			local critical = (isCritical == true)
			hitComp:OnHit(targetEntity, math.ceil(damage), critical, "ATTACK", 1)
		end
	end
	method void MonsterBasicAttack(integer index)
		local monster = self.monsterList[index]
		if monster == nil or monster.alive == false then
			self.lastActionValid = false
			return
		end
		
		self.lastActionValid = true
		self.lastDamage = monster.atk or 0
		self.lastHitCount = 1
		self.lastStatus = "none"
		self.lastDotDmg = 0
		self.lastDotTurn = 0
		
		local animTargetId = monster.animEntityId
		if animTargetId == nil then animTargetId = monster.entityId end
		self:PlayEntityState(animTargetId, "ATTACK1", 0)
	end
	method void MonsterSkillAttack(integer index)
		local monster = self.monsterList[index]
		if monster == nil or monster.alive == false then
			self.lastActionValid = false
			return
		end
		
		self.lastActionValid = true
		self.lastDamage = monster.atk or 0
		self.lastHitCount = 1
		self.lastDotDmg = monster.dotDmg
		self.lastDotTurn = monster.dotTurn
		
		local patternKey = string.lower(monster.patternId or "")
		patternKey = string.gsub(patternKey, "^%s+", "")
		patternKey = string.gsub(patternKey, "%s+$", "")
		
		if patternKey == "poison" then
			self.lastStatus = "poison"
		elseif patternKey == "multi" then
			self.lastStatus = "multi"
			self.lastHitCount = monster.atkCount or 2
			if self.lastHitCount <= 0 then
				self.lastHitCount = 2
			end
		else
			local statusKey = string.lower(monster.status or "")
			statusKey = string.gsub(statusKey, "^%s+", "")
			statusKey = string.gsub(statusKey, "%s+$", "")
			if statusKey == "multi" then
				self.lastStatus = "multi"
				self.lastHitCount = monster.atkCount or 2
				if self.lastHitCount <= 0 then
					self.lastHitCount = 2
				end
			elseif statusKey == "poison" then
				self.lastStatus = "poison"
		else
			self.lastStatus = monster.status
		end
	end
		
		local animTargetId = monster.animEntityId
		if animTargetId == nil then animTargetId = monster.entityId end
		self:PlayEntityState(animTargetId, "SKILL1", 0)
	end
	method void MonsterAction(integer index)
		local monster = self.monsterList[index]
		if monster == nil or monster.alive == false then
			self.lastActionValid = false
			return
		end
		
		if monster.isBoss then
			self:BossAction()
			return
		end
		
		local patternKey = string.lower(monster.patternId or "")
		patternKey = string.gsub(patternKey, "^%s+", "")
		patternKey = string.gsub(patternKey, "%s+$", "")
		if patternKey == "multi" then
			self:MonsterSkillAttack(index)
			return
		end
		
		local patternProb = monster.patternProb or 0
		if patternProb < 0 then patternProb = 0 end
		if patternProb > 100 then patternProb = 100 end
		
		local roll = math.random(1, 100)
		if roll <= patternProb then
			self:MonsterSkillAttack(index)
		else
			self:MonsterBasicAttack(index)
		end
	end

	method void BossAction()
		if self.isBossBattle == false or #self.monsterList == 0 then
			self.lastActionValid = false
			return
		end
		
		local boss = self.monsterList[1]
		if boss == nil or boss.alive == false then
			self.lastActionValid = false
			return
		end
		
		local patterns = self.dataManager:GetBossPatterns(self.currentBossId, self.currentBossPhase)
		if patterns == nil or #patterns == 0 then
			log_error("[MonsterManager] 보스 ?�턴???�습?�다.")
			self.lastActionValid = false
			return
		end
		
		local patternIdx = math.random(1, #patterns)
		local pattern = patterns[patternIdx]
		
		self.lastActionValid = true
		self.lastHitCount = 1
		
		-- Use our property fields to pass skill details to BattleManager
		self.lastStatus = pattern.effectType  -- 'hp_dmg', 'poison', 'shield', 'heal'
		self.lastDamage = pattern.effectValue -- percentage or value
		self.lastDotTurn = pattern.turn -- turns for poison, or 1 for shield
		self.lastPatternDuration = pattern.duration or 1.5
		
		log("[MonsterManager] 보스?�킬 발동: " .. pattern.name .. " [?�?? " .. self.lastStatus .. "] (밸류:" .. tostring(self.lastDamage) .. ")")
		
		-- 보스 ?�신 ?�???�킬 처리 (shield, heal)
		if self.lastStatus == "shield" then
			boss.shieldActive = true
			log("[MonsterManager] 보스가 ??방어??쳤?니??")
		elseif self.lastStatus == "heal" then
			local healAmount = math.floor(boss.maxHP * (self.lastDamage / 100.0))
			boss.currentHP = math.min(boss.maxHP, boss.currentHP + healAmount)
			log("[MonsterManager] 보스가 체력??" .. tostring(healAmount) .. " ?복?습?다! (?재 HP: " .. tostring(boss.currentHP) .. ")")
			
			-- Removed NameTag HP Update
		end
		
		local animTargetId = boss.animEntityId
		if animTargetId == nil then animTargetId = boss.entityId end
		self:PlayEntityState(animTargetId, "SKILL1", 2.0)
		local gameSystem = _EntityService:GetEntityByPath("/maps/map01/GameSystem")
		if gameSystem and gameSystem.SoundManager then
			local t = "boss_atk_" .. tostring(pattern.effectType)
			gameSystem.SoundManager:PlaySFXByTitle(t, 0)
		end
	end

	method void ApplyIncomingDamageDebuff(integer index, number percent, integer turn)
		local monster = self.monsterList[index]
		if monster == nil or monster.alive == false then
			return
		end
		if percent == nil or percent <= 0 then
			return
		end
		
		local applyTurn = turn or 1
		if applyTurn <= 0 then
			applyTurn = 1
		end
		
		local currentPercent = monster.incomingDmgUp or 0
		local currentTurn = monster.incomingDmgUpTurn or 0
		monster.incomingDmgUp = math.max(currentPercent, percent)
		monster.incomingDmgUpTurn = math.max(currentTurn, applyTurn)
		
		log("[MonsterManager] Incoming dmg debuff applied: " .. monster.name .. " +" .. tostring(monster.incomingDmgUp) .. "% (" .. tostring(monster.incomingDmgUpTurn) .. " turns)")
	end
	
	method void TickMonsterDebuffs()
		for i = 1, #self.monsterList do
			local monster = self.monsterList[i]
			if monster ~= nil and monster.incomingDmgUpTurn ~= nil and monster.incomingDmgUpTurn > 0 then
				monster.incomingDmgUpTurn -= 1
				if monster.incomingDmgUpTurn <= 0 then
					monster.incomingDmgUpTurn = 0
					monster.incomingDmgUp = 0
					if monster.alive then
						log("[MonsterManager] Incoming dmg debuff expired: " .. monster.name)
					end
				end
			end
		end
	end
	method integer GetAliveCount()
		local count = 0
		for i = 1, #self.monsterList do
			if self.monsterList[i] ~= nil and self.monsterList[i].alive == true then
				count += 1
			end
		end
		return count
	end
	
	method integer GetFirstAliveMonsterIndex()
		for i = 1, #self.monsterList do
			local monster = self.monsterList[i]
			if monster ~= nil and monster.alive == true then
				return i
			end
		end
		return 0
	end

	method boolean IsAllDead()
		return self:GetAliveCount() == 0
	end

	method void CollectRewards()
		local totalExp = 0
		local totalGold = 0
		for i = 1, #self.monsterList do
			local monster = self.monsterList[i]
			if monster ~= nil then
				totalExp += monster.rewardExp or 0
				totalGold += monster.rewardGold or 0
			end
		end
		self.lastRewardExp = totalExp
		self.lastRewardGold = totalGold
		log("[MonsterManager] " .. tostring(totalExp) .. " Gold: " .. tostring(totalGold))
	end

	method void ClearAll(boolean skipDestroy)
		if skipDestroy ~= true then
			local destroyedById = {}
			local function destroyEntityById(entityId)
				if entityId == nil then
					return
				end
				local key = tostring(entityId)
				if key == "" or destroyedById[key] == true then
					return
				end
				destroyedById[key] = true
				local entity = _EntityService:GetEntity(entityId)
				if entity ~= nil then
					_EntityService:Destroy(entity)
				end
			end
			
			for i = 1, #self.monsterList do
				local mon = self.monsterList[i]
				if mon ~= nil then
					destroyEntityById(mon.animEntityId)
					destroyEntityById(mon.entityId)
				end
			end
			
			-- Fallback cleanup for stale visuals (e.g. defeat path that already cleared monsterList).
			local parentEntity = self.Entity.Parent
			if parentEntity ~= nil and parentEntity.Children ~= nil then
				local children = parentEntity.Children
				for i = 1, #children do
					local child = children[i]
					if child ~= nil then
						local childName = tostring(child.Name or "")
						if string.sub(childName, 1, 8) == "Monster_" then
							_EntityService:Destroy(child)
						end
					end
				end
			end
		end
		self.monsterList = {}
		self.isBossBattle = false
		self.currentBossId = ""
		self.currentBossPhase = 1
		self.pendingSpawnEntranceCount = 0
		self.isPhaseTransitioning = false
		self.isDyingAnimating = false
	end

	method void SpawnVisual(table monster, integer index, boolean isBoss, integer totalCount)
		--
		-- index 1 -> x=7, index 2 -> x=9, index 3 -> x=11 ...
		local xPos = 5 + (index - 1) * 2
		local yPos = 0
		local targetX = xPos
		local targetY = yPos
		
		log("[MonsterManager] SpawnVisual: index=" .. tostring(index) .. " isBoss=" .. tostring(isBoss) .. " monsterSpawnArea=" .. tostring(self.monsterSpawnArea) .. " areaWidth=" .. tostring(self.monsterSpawnAreaWidth))
		if isBoss and self.bossSpawnPoint ~= nil then
			local spawnPos = self.bossSpawnPoint.TransformComponent.Position
			xPos = spawnPos.x
			yPos = spawnPos.y
			targetX = xPos
			targetY = yPos
			log("[MonsterManager] Boss spawn at entity position: X=" .. tostring(xPos) .. " Y=" .. tostring(yPos))
		elseif not isBoss and self.monsterSpawnArea ~= nil then
			local areaPos = self.monsterSpawnArea.TransformComponent.WorldPosition
			local areaWidth = self.monsterSpawnArea.TransformComponent.Scale.x
			
			log("[MonsterManager] Area debug: areaX=" .. tostring(areaPos.x) .. " width=" .. tostring(areaWidth) .. " total=" .. tostring(totalCount) .. " index=" .. tostring(index))
			
			local leftEdge = areaPos.x - (areaWidth / 2)
			
			if totalCount <= 1 then
				xPos = areaPos.x
			else
				-- Divide the area into 'totalCount' slots and place each monster in the center of its slot
				local slotWidth = areaWidth / totalCount
				xPos = leftEdge + (slotWidth / 2) + ((index - 1) * slotWidth)
			end
			yPos = areaPos.y
			targetX = xPos
			targetY = yPos
			log("[MonsterManager] Monster " .. tostring(index) .. " spawn: X=" .. tostring(xPos) .. " Y=" .. tostring(yPos) .. " width=" .. tostring(areaWidth))
		end

		local spawnX = targetX
		local spawnY = targetY
		if not isBoss then
			spawnX = targetX + (self.spawnEntranceOffsetX or 0)
		end
		
		--
		local spawnModelId = self.modelId
		if monster.modelID ~= nil and monster.modelID ~= "" then
			spawnModelId = monster.modelID
		end
		
		log("[DEBUG-MON] Spawning Visual: Index=" .. tostring(index) .. " ModelID=" .. tostring(spawnModelId))
		
		local entity = _SpawnService:SpawnByModelId(spawnModelId, "Monster_" .. tostring(index), Vector3(spawnX, spawnY, 0), self.Entity.Parent)
		if entity ~= nil then
			
			if isBoss and self.currentBossPhase == 1 then
				if entity.TransformComponent ~= nil then
					local curScale = entity.TransformComponent.Scale
					entity.TransformComponent.Scale = Vector3(curScale.x * 1.7, curScale.y * 1.7, curScale.z)
				end
			end
			
			--
			local touch = entity.TouchReceiveComponent
			if touch == nil then
				entity:AddComponent("TouchReceiveComponent")
				touch = entity.TouchReceiveComponent
			end
			
			monster.entityId = entity.Id
			
			local nameTag = entity.NameTagComponent
			if nameTag ~= nil then
				nameTag.Enable = false
			end
			
			local sprite = entity.SpriteRendererComponent
			if sprite ~= nil then
				sprite.FlipX = false
				sprite.OrderInLayer = 10
			end
			
			local stateAnim = entity.StateAnimationComponent
			if stateAnim ~= nil then
				stateAnim.Enable = true
			end
			
			--
			entity:ConnectEvent("TouchEvent", function(event)
				self:OnMonsterTouch(index)
			end)
			
			--
			local monsterComp = entity.MonsterComponent
			if monsterComp ~= nil then monsterComp.Enable = false end
			
			local moveComp = entity.MovementComponent
			if moveComp ~= nil then moveComp.Enable = false end
			
			local rigidComp = entity.RigidbodyComponent
			if rigidComp ~= nil then
				rigidComp.Enable = false
				rigidComp.MoveVelocity = Vector2.zero
				rigidComp:SetForce(Vector2.zero)
			end
			
			--
			log("[DEBUG] Checking components on " .. entity.Name .. ":")
			local c1 = entity.SpriteAnimPlayerComponent
			local c2 = entity.AnimatorComponent
			local c3 = entity.AvatarRendererComponent
			local c4 = entity.StateAnimationComponent
			
			if c1 ~= nil then log(" - SpriteAnimPlayerComponent: OK") end
			if c2 ~= nil then log(" - AnimatorComponent: OK") end
			if c3 ~= nil then log(" - AvatarRendererComponent: OK") end
			if c4 ~= nil then log(" - StateAnimationComponent: OK") end
			
			--
			log("[DEBUG] === Inspecting Entity: " .. entity.Name .. " ===")
			local comps = entity.Components
			if comps ~= nil then
				local count = 0
				--
				--
				--
				--
				--
				--
				-- Try simple iteration if it is a table-like userdata.
				--
				--
				-- Wait, docs say "ReadOnlyList".
				-- Let's assume we can't iterate.
				-- But I MUST know what's there.
			end
			
			--
			local animCandidates = {
				"SpriteAnimPlayerComponent",
				"AnimatorComponent",
				"AvatarRendererComponent",
				"StateAnimationComponent",
				"TweenLineComponent",
				"EffectComponent",
				"BeholderComponent" --
			}
			
			for i, name in ipairs(animCandidates) do
				local c = entity:GetComponent(name)
				if c ~= nil then log(" - Found on Root: " .. name) end
			end
			
			--
			local children = entity.Children
			if children ~= nil then
				-- Children is ReadOnlyList.
				-- Let's NOT iterate with pairs if it fails.
				--
				-- "Total Children: 0" (if logged).
				--
				-- So we CANNOT iterate Children with pairs.
				
				--
				-- No, that just gets components.
			end
			
			--
			monster.animEntityId = entity.Id
			log("[MonsterManager] " .. monster.name)

			if not isBoss and math.abs(spawnX - targetX) > 0.001 then
				self.pendingSpawnEntranceCount += 1
				self:StartSpawnEntrance(monster, targetX, targetY)
			end
		else
			log("[MonsterManager] " .. spawnModelId)
		end
	end

	method boolean IsSpawnEntranceFinished()
		return (self.pendingSpawnEntranceCount or 0) <= 0
	end

	method void SetEntityWorldPosition(any entity, number xPos, number yPos)
		if entity == nil or entity.TransformComponent == nil then
			return
		end
		local curPos = entity.TransformComponent.Position
		entity.TransformComponent.Position = Vector3(xPos, yPos, curPos.z)
		entity.TransformComponent.WorldPosition = Vector3(xPos, yPos, curPos.z)
	end

	method Vector3 GetEntityWorldPosition(any entity)
		if entity == nil or entity.TransformComponent == nil then
			return Vector3(0, 0, 0)
		end
		return entity.TransformComponent.WorldPosition
	end

	method void StartSpawnEntrance(table monster, number targetX, number targetY)
		if monster == nil then
			return
		end
		local targetEntityId = monster.animEntityId
		if targetEntityId == nil or targetEntityId == "" then
			targetEntityId = monster.entityId
		end
		if targetEntityId == nil or targetEntityId == "" then
			return
		end
		
		local entity = _EntityService:GetEntity(targetEntityId)
		if entity == nil or entity.TransformComponent == nil then
			return
		end
		
		local duration = self.spawnEntranceDuration or 0.45
		local steps = self.spawnEntranceSteps or 9
		if steps <= 0 then
			steps = 1
		end
		if duration <= 0 then
			entity.TransformComponent.Position = Vector3(targetX, targetY, entity.TransformComponent.Position.z)
			return
		end
		
		local startPos = self:GetEntityWorldPosition(entity)
		local stepDelay = duration / steps
		local step = 0
		
		self:PlayEntityState(targetEntityId, "MOVE", 0)
		
		local moveStep = nil
		moveStep = function()
			local aliveEntity = _EntityService:GetEntity(targetEntityId)
			if aliveEntity == nil or aliveEntity.TransformComponent == nil then
				return
			end
			
			step += 1
			local t = step / steps
			if t > 1 then
				t = 1
			end
			
			local newX = startPos.x + ((targetX - startPos.x) * t)
			local newY = startPos.y + ((targetY - startPos.y) * t)
			self:SetEntityWorldPosition(aliveEntity, newX, newY)
			
			if step < steps then
				_TimerService:SetTimerOnce(moveStep, stepDelay)
			else
				self.pendingSpawnEntranceCount = math.max(0, (self.pendingSpawnEntranceCount or 0) - 1)
				self:PlayEntityState(targetEntityId, "STAND", 0)
				
				if self.pendingSpawnEntranceCount == 0 and self.uiMain ~= nil then
					self.uiMain:UpdateUI()
				end
			end
		end
		
		_TimerService:SetTimerOnce(moveStep, stepDelay)
	end

	method void OnMonsterTouch(integer index)
		log("[MonsterManager] " .. tostring(index))
		if self.uiMain ~= nil then
			self.uiMain:OnClickMonster(index)
		else
			log("[MonsterManager] ")
		end
	end
	
	method table FindMonsterByEntityId(string entityId)
		if entityId == nil or entityId == "" then return nil end
		for i = 1, #self.monsterList do
			local m = self.monsterList[i]
			if m ~= nil then
				if m.entityId == entityId or m.animEntityId == entityId then
					return m
				end
			end
		end
		return nil
	end

	method void PlayEntityState(string entityId, string stateName, number duration)
		log("[MonsterManager] " .. tostring(entityId) .. " state=" .. tostring(stateName))
		if entityId == nil or entityId == "" then return end
		
		local entity = _EntityService:GetEntity(entityId)
		if entity == nil then return end
		
		local stateAnim = entity.StateAnimationComponent
		local spriteRenderer = entity.SpriteRendererComponent
		
		if stateAnim == nil then return end
		
		local sheet = stateAnim.ActionSheet
		if sheet == nil then return end
		
		local idleKey = "stand"
		if sheet["stand"] ~= nil then
			idleKey = "stand"
		elseif sheet["fly"] ~= nil then
			idleKey = "fly"
		elseif sheet["move"] ~= nil then
			idleKey = "move"
		elseif sheet["walk"] ~= nil then
			idleKey = "walk"
		end
		
		local sheetKey = idleKey
		if stateName == "HIT" then
			sheetKey = "hit"
		elseif stateName == "ATTACK1" or stateName == "SKILL1" then
			if sheet["attack"] ~= nil then
				sheetKey = "attack"
			elseif sheet["attack1"] ~= nil then
				sheetKey = "attack1"
			elseif sheet["skill"] ~= nil then
				sheetKey = "skill"
			elseif sheet["skill1"] ~= nil then
				sheetKey = "skill1"
			elseif sheet["move"] ~= nil then
				sheetKey = "move"
			else
				sheetKey = idleKey
			end
		elseif stateName == "MOVE" then
			if sheet["move"] ~= nil then
				sheetKey = "move"
			elseif sheet["walk"] ~= nil then
				sheetKey = "walk"
			elseif sheet["fly"] ~= nil then
				sheetKey = "fly"
			else
				sheetKey = idleKey
			end
		elseif stateName == "DIE" then
			sheetKey = "die"
		end
		
		local played = false
		stateAnim.Enable = true
		played = pcall(function()
			stateAnim:ReceiveStateChangeEvent(self, StateChangeEvent(sheetKey, idleKey))
		end)
		if played then
			log("[MonsterManager] state anim key=" .. tostring(sheetKey))
		end
		
		-- Last fallback (non-animated): if state animation path failed.
		if played == false then
			if spriteRenderer ~= nil then
				local targetRUID = sheet[sheetKey]
				if targetRUID == nil or targetRUID == "" then
					targetRUID = sheet[string.upper(sheetKey)] or sheet[string.lower(sheetKey)]
				end
				if targetRUID ~= nil and targetRUID ~= "" then
					spriteRenderer.SpriteRUID = targetRUID
					log("[MonsterManager] sprite fallback ruid=" .. tostring(targetRUID))
				end
			end
		end
		
		if duration > 0 and stateName ~= "DIE" then
			_TimerService:SetTimerOnce(function()
				pcall(function()
					local aliveEntity = _EntityService:GetEntity(entityId)
					if aliveEntity == nil then return end
					local aliveStateAnim = aliveEntity.StateAnimationComponent
					local restored = false
					if aliveStateAnim ~= nil then
						aliveStateAnim.Enable = true
						restored = pcall(function()
							aliveStateAnim:ReceiveStateChangeEvent(self, StateChangeEvent(idleKey, sheetKey))
						end)
					end
					if restored == false then
						local aliveSprite = aliveEntity.SpriteRendererComponent
						local idleRUID = sheet[idleKey]
						if aliveSprite ~= nil and idleRUID ~= nil and idleRUID ~= "" then
							aliveSprite.SpriteRUID = idleRUID
						end
					end
				end)
			end, duration)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateTargetHighlight(integer targetIndex)
		if not self:IsClient() then
			return
		end
		--
		if self.targetIndicator == nil then
			self.targetIndicator = _EntityService:GetEntityByPath(self.targetIndicatorPath)
			if self.targetIndicator ~= nil then
				-- If indicator is an image UI entity, allow runtime RUID binding from inspector.
				local gui = self.targetIndicator.SpriteGUIRendererComponent
				if gui ~= nil then
					if self.targetIndicatorImageRUID ~= nil and self.targetIndicatorImageRUID ~= "" then
						gui.ImageRUID = self.targetIndicatorImageRUID
						self.targetIndicatorBoundRUID = self.targetIndicatorImageRUID
					else
						self.targetIndicatorBoundRUID = tostring(gui.ImageRUID or "")
					end
					gui.AnimClipPlayType = SpriteAnimClipPlayType.Loop
					if gui.PlayRate == nil or gui.PlayRate <= 0 then
						gui.PlayRate = 1
					end
				end
				-- Scale the arrow to half size
				local uiTrans = self.targetIndicator.UITransformComponent
				if uiTrans ~= nil then
					local curSize = uiTrans.RectSize
					uiTrans.RectSize = Vector2(curSize.x * 0.5, curSize.y)
				end
				self.targetIndicator.Enable = false
				self.targetIndicatorWasVisible = false
			else
				log_warning("[MonsterManager] TargetIndicator UI not found: " .. tostring(self.targetIndicatorPath))
			end
		end
		
		local validTargetEntity = nil
		
		for i = 1, #self.monsterList do
			local monster = self.monsterList[i]
			if monster ~= nil and monster.entityId ~= nil then
				local entity = _EntityService:GetEntity(monster.entityId)
				if entity ~= nil then
					if i == targetIndex and monster.alive then
						validTargetEntity = entity
					end
				end
			end
		end
		
		--
		if self.targetIndicator ~= nil then
			if validTargetEntity ~= nil then
				local isBoss = false
				if self.monsterList[targetIndex] ~= nil then
					isBoss = self.monsterList[targetIndex].isBoss == true
				end
				
				if isBoss then
					if self.uiMain ~= nil and self.uiMain.UpdateTargetIndicatorPosition ~= nil then
						self.uiMain:UpdateTargetIndicatorPosition(self.targetIndicator, Vector3(0, 0, 0), false)
					else
						self.targetIndicator.Enable = false
					end
					self.targetIndicatorWasVisible = false
				else
					local targetPos = validTargetEntity.TransformComponent.Position
					local arrowOffset = 1.2
					local targetMonster = self.monsterList[targetIndex]
					if targetMonster ~= nil and targetMonster.arrowOffsetY ~= nil then
						arrowOffset = targetMonster.arrowOffsetY
					end
					local worldPos = Vector3(targetPos.x, targetPos.y + arrowOffset, 1)
					local wasVisible = self.targetIndicatorWasVisible
					if self.uiMain ~= nil and self.uiMain.UpdateTargetIndicatorPosition ~= nil then
						self.uiMain:UpdateTargetIndicatorPosition(self.targetIndicator, worldPos, true)
					else
						self.targetIndicator.Enable = true
						self.targetIndicator.TransformComponent.Position = worldPos
					end
					-- Keep loop/play settings, but avoid re-binding the same RUID every update.
					local gui = self.targetIndicator.SpriteGUIRendererComponent
					if gui ~= nil then
						gui.AnimClipPlayType = SpriteAnimClipPlayType.Loop
						if gui.PlayRate == nil or gui.PlayRate <= 0 then
							gui.PlayRate = 1
						end
						local ruid = self.targetIndicatorImageRUID
						if ruid ~= nil and ruid ~= "" and ruid ~= self.targetIndicatorBoundRUID then
							gui.ImageRUID = ruid
							self.targetIndicatorBoundRUID = ruid
						elseif wasVisible == false then
							-- Trigger animation start once when indicator becomes visible.
							local activeRUID = ruid
							if activeRUID == nil or activeRUID == "" then
								activeRUID = gui.ImageRUID
							end
							if activeRUID ~= nil and tostring(activeRUID) ~= "" then
								-- Some runtimes do not restart anim when assigning the same RUID.
								-- Toggle through empty once to force clip player refresh.
								gui.ImageRUID = ""
								gui.ImageRUID = activeRUID
							end
						end
					end
					self.targetIndicatorWasVisible = true
				end
			else
				if self.uiMain ~= nil and self.uiMain.UpdateTargetIndicatorPosition ~= nil then
					self.uiMain:UpdateTargetIndicatorPosition(self.targetIndicator, Vector3(0, 0, 0), false)
				else
					self.targetIndicator.Enable = false
				end
				self.targetIndicatorWasVisible = false
			end
		end
	end

end



