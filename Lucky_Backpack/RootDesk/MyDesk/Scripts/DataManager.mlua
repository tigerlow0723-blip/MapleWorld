@Component
script DataManager extends Component

	property table MonsterTable = {}

	property table BossTable = {}

	property table BossBasicTable = {}

	property table SpawnTable = {}

	property table ItemTable = {}

	property table BaseStatTable = {}

	property table LevelStatTable = {}

	property table SkillTable = {}

	property table CorrectionTable = {}

	property table MapTable = {}

	property table StageWeightTable = {}

	property table SpecialEventTable = {}

	method void OnInitialize()
		log("[DataManager] (OnInitialize)  (  : Server/Client)")
	end

	method void OnBeginPlay()
		self:LoadAllTables()
		log("[DataManager]     ")
	end

	method void LoadAllTables()
		self:LoadMonsterTable()
		self:LoadBossTable()
		self:LoadSpawnTable()
		self:LoadItemTable()
		self:LoadBaseStatTable()
		self:LoadLevelStatTable()
		self:LoadSkillTable()
		self:LoadCorrectionTable()
		self:LoadMapTable()
		self:LoadStageWeightTable()
		self:LoadSpecialEventTable()
		
		log("[DataManager]      .")
	end

	method any GetDataSet(string tableName)
		local ds = _DataService:GetTable(tableName)
		if ds == nil then
			log("[ERROR] [DataManager]    : " .. tableName)
			return nil
		end
		return ds
	end

	method string GetCellString(any ds, integer row, string colA, string colB)
		if ds == nil then
			return ""
		end
		
		local value = self:TryGetCell(ds, row, colA)
		if value ~= nil and value ~= "" then
			return tostring(value)
		end
		
		if colB ~= nil and colB ~= "" then
			local valueB = self:TryGetCell(ds, row, colB)
			if valueB ~= nil and valueB ~= "" then
				return tostring(valueB)
			end
		end
		
		return ""
	end

	method any TryGetCell(any ds, integer row, string colName)
		if ds == nil or colName == nil or colName == "" then
			return nil
		end
		
		local ok, value = pcall(function()
			return ds:GetCell(row, colName)
		end)
		
		if ok then
			return value
		end
		
		return nil
	end

